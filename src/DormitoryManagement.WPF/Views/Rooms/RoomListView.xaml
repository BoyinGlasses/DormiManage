<UserControl x:Class="DormitoryManagement.WPF.Views.Rooms.RoomListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             Loaded="OnLoaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <controls:PageHeader Title="Rooms" Subtitle="Search rooms by building, status, gender type, and occupancy.">
                    <controls:PageHeader.Actions>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Refresh" Command="{Binding LoadCommand}" />
                        </StackPanel>
                    </controls:PageHeader.Actions>
                </controls:PageHeader>

                <controls:ErrorState Title="Could not load rooms"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,14" />

                <controls:SearchFilterBar>
                    <controls:SearchFilterBar.FilterContent>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Keyword" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Search rooms by keyword" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Building" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding BuildingOptions}" SelectedItem="{Binding SelectedBuilding}" AutomationProperties.Name="Building filter" />
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" AutomationProperties.Name="Room status filter" />
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Gender type" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding GenderTypeOptions}" SelectedItem="{Binding SelectedGenderType}" AutomationProperties.Name="Gender type filter" />
                            </StackPanel>

                            <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                <Button Content="Apply" Command="{Binding ApplyFiltersCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                <Button Content="Clear" Command="{Binding ClearFiltersCommand}" />
                            </StackPanel>
                        </Grid>
                    </controls:SearchFilterBar.FilterContent>
                </controls:SearchFilterBar>

                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Room inventory" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0" />
                            <TextBlock Text="{Binding TotalCount, StringFormat={}{0} total}" Style="{StaticResource CaptionText}" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                        </DockPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Rooms}" Visibility="{Binding HasRooms, Converter={StaticResource BoolToVisibility}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Building" Binding="{Binding BuildingName}" Width="1.4*" />
                                <DataGridTextColumn Header="Floor" Binding="{Binding FloorNumber}" Width="0.7*" />
                                <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="*" />
                                <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="0.8*" />
                                <DataGridTextColumn Header="Held" Binding="{Binding HeldSlots}" Width="0.7*" />
                                <DataGridTextColumn Header="Available" Binding="{Binding AvailableSlots}" Width="0.9*" />
                                <DataGridTemplateColumn Header="Occupancy" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding CurrentOccupancy}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding Capacity}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Gender" Binding="{Binding GenderType}" Width="*" />
                                <DataGridTextColumn Header="Base Price" Binding="{Binding MonthlyPrice, StringFormat=N0}" Width="*" />
                                <DataGridTemplateColumn Header="Status" Width="1.2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <controls:StatusBadge Status="{Binding Status}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <controls:EmptyState Grid.Row="1"
                                             Title="No rooms found"
                                             Message="Rooms will appear here after room data is added or when filters match existing rooms."
                                             Icon="▤"
                                             Visibility="{Binding IsRoomsEmpty, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <controls:LoadingOverlay Message="Loading rooms..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
