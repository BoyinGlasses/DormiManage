<UserControl x:Class="DormitoryManagement.WPF.Views.Shared.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audit="clr-namespace:DormitoryManagement.WPF.Views.Audit"
             xmlns:auth="clr-namespace:DormitoryManagement.WPF.Views.Auth"
             xmlns:dash="clr-namespace:DormitoryManagement.WPF.Views.Dashboard"
             xmlns:students="clr-namespace:DormitoryManagement.WPF.Views.Students"
             xmlns:rooms="clr-namespace:DormitoryManagement.WPF.Views.Rooms"
             xmlns:billing="clr-namespace:DormitoryManagement.WPF.Views.Billing"
             xmlns:registrations="clr-namespace:DormitoryManagement.WPF.Views.Registrations"
             xmlns:vehicles="clr-namespace:DormitoryManagement.WPF.Views.Vehicles"
             xmlns:tickets="clr-namespace:DormitoryManagement.WPF.Views.SupportTickets"
             xmlns:forum="clr-namespace:DormitoryManagement.WPF.Views.Forum"
             xmlns:profile="clr-namespace:DormitoryManagement.WPF.Views.Profile"
             xmlns:settings="clr-namespace:DormitoryManagement.WPF.Views.Settings"
             xmlns:shared="clr-namespace:DormitoryManagement.WPF.Views.Shared"
             xmlns:vmAudit="clr-namespace:DormitoryManagement.WPF.ViewModels.Audit"
             xmlns:vmAuth="clr-namespace:DormitoryManagement.WPF.ViewModels.Auth"
             xmlns:vmDash="clr-namespace:DormitoryManagement.WPF.ViewModels.Dashboard"
             xmlns:vmStudents="clr-namespace:DormitoryManagement.WPF.ViewModels.Students"
             xmlns:vmRooms="clr-namespace:DormitoryManagement.WPF.ViewModels.Rooms"
             xmlns:vmBilling="clr-namespace:DormitoryManagement.WPF.ViewModels.Billing"
             xmlns:vmRegistrations="clr-namespace:DormitoryManagement.WPF.ViewModels.Registrations"
             xmlns:vmVehicles="clr-namespace:DormitoryManagement.WPF.ViewModels.Vehicles"
             xmlns:vmTickets="clr-namespace:DormitoryManagement.WPF.ViewModels.SupportTickets"
             xmlns:vmForum="clr-namespace:DormitoryManagement.WPF.ViewModels.Forum"
             xmlns:vmProfile="clr-namespace:DormitoryManagement.WPF.ViewModels.Profile"
             xmlns:vmSettings="clr-namespace:DormitoryManagement.WPF.ViewModels.Settings"
             TextElement.Foreground="{StaticResource TextPrimaryBrush}">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vmAudit:AuditLogListViewModel}"><audit:AuditLogListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmAuth:LoginViewModel}"><auth:LoginView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmAuth:RegisterViewModel}"><auth:RegisterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmDash:AdminDashboardViewModel}"><dash:AdminDashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmDash:StudentDashboardViewModel}"><dash:StudentDashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmStudents:StudentListViewModel}"><students:StudentListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmStudents:StudentDetailViewModel}"><students:StudentDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmRooms:RoomListViewModel}"><rooms:RoomListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmRooms:RoomDetailViewModel}"><rooms:RoomDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmRegistrations:RoomRegistrationViewModel}"><registrations:RoomRegistrationView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmRegistrations:RegistrationApprovalViewModel}"><registrations:RegistrationApprovalView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmBilling:InvoiceListViewModel}"><billing:InvoiceListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmBilling:InvoiceDetailViewModel}"><billing:InvoiceDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmBilling:PaymentViewModel}"><billing:PaymentView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmBilling:DebtListViewModel}"><billing:DebtListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmVehicles:VehicleRegistrationViewModel}"><vehicles:VehicleRegistrationView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmTickets:SupportTicketListViewModel}"><tickets:SupportTicketListView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmTickets:SupportTicketDetailViewModel}"><tickets:SupportTicketDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmForum:ForumHomeViewModel}"><forum:ForumHomeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmForum:ForumPostDetailViewModel}"><forum:ForumPostDetailView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmProfile:ProfileViewModel}"><profile:ProfileView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmSettings:UserManagementViewModel}"><settings:UserManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vmSettings:FeeTypeViewModel}"><settings:FeeTypeView /></DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <ContentControl Content="{Binding CurrentViewModel}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibility}}" />

        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
            <Border x:Name="SidebarPanel"
                    Width="{x:Static shared:ShellViewAnimationSettings.SidebarWidth}"
                    Background="{StaticResource SidebarBrush}"
                    GotKeyboardFocus="OnSidebarKeyboardFocus"
                    HorizontalAlignment="Left"
                    IsHitTestVisible="False"
                    KeyboardNavigation.TabNavigation="Continue"
                    MouseEnter="OnSidebarMouseEnter"
                    MouseLeave="OnSidebarMouseLeave"
                    Panel.ZIndex="10">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SidebarTransform"
                                        X="{x:Static shared:ShellViewAnimationSettings.HiddenOffset}" />
                </Border.RenderTransform>
                <DockPanel LastChildFill="True" Margin="22">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="8"
                                    Background="{StaticResource AccentBrush}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="DM"
                                           Foreground="{StaticResource TextInvertedBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Dormitory"
                                           Foreground="{StaticResource TextInvertedBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Management Console"
                                           Foreground="{StaticResource SidebarTextBrush}"
                                           FontSize="12"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                        <Border Height="1" Background="#2B3A55" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom"
                            Background="#22314A"
                            BorderBrush="#31415F"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14"
                            Margin="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource SidebarActiveBrush}">
                                <TextBlock Text="U"
                                           Foreground="{StaticResource SidebarTextActiveBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUserName}"
                                           Foreground="{StaticResource TextInvertedBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding RoleText}"
                                           Foreground="{StaticResource SidebarTextBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="MAIN"
                                       Foreground="{StaticResource SidebarTextBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="4,0,0,10" />
                            <ItemsControl ItemsSource="{Binding MenuItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Key}"
                                                Style="{StaticResource SidebarButtonStyle}"
                                                ToolTip="{Binding Title}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="38" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="25"
                                                        Height="26"
                                                        CornerRadius="6"
                                                        Background="Transparent"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Icon}"
                                                               FontFamily="Segoe Fluent Icons"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid x:Name="MainContentHost"
                  Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <shared:TopBar Grid.Row="0"
                               Visibility="{Binding IsTopBarVisible, Converter={StaticResource BoolToVisibility}}" />

                <Border x:Name="ContentHostBorder"
                        Grid.Row="1"
                        Background="{StaticResource BackgroundBrush}"
                        Style="{StaticResource StudentDashboardShellContentBorderStyle}">
                    <ContentControl Content="{Binding CurrentViewModel}" />
                </Border>
            </Grid>

            <Border x:Name="SidebarHotspot"
                    Width="{x:Static shared:ShellViewAnimationSettings.HotspotWidth}"
                    Background="Transparent"
                    Focusable="False"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    IsHitTestVisible="True"
                    MouseEnter="OnSidebarHotspotMouseEnter"
                    Panel.ZIndex="20" />
        </Grid>
    </Grid>
</UserControl>







