<mah:MetroWindow x:Class="DormitoryManagement.WPF.Views.Shared.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:DormitoryManagement.WPF.Views.Shared"
                 Title="Dormitory Management"
                 Width="1360"
                 Height="840"
                 MinWidth="1100"
                 MinHeight="680"
                 Background="{StaticResource BackgroundBrush}"
                 TextElement.Foreground="{StaticResource TextPrimaryBrush}"
                 GlowBrush="{StaticResource AccentBrush}"
                 BorderBrush="{StaticResource BorderBrush}"
                 WindowStartupLocation="CenterScreen"
                 WindowState="Maximized">
    <views:ShellView />
</mah:MetroWindow>
