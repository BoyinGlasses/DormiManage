<UserControl x:Class="DormitoryManagement.WPF.Views.Shared.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore">

    <Grid>
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="{StaticResource StudentDashboardHeaderMinHeight}"
                Visibility="{Binding IsDefaultTopBarChrome, Converter={StaticResource BoolToVisibility}}">
            <DockPanel Margin="28,0">
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentPageTitle}" Style="{StaticResource TitleText}" />
                    <TextBlock Text="Dormitory operations, finance, and resident services"
                               Style="{StaticResource CaptionText}"
                               Margin="0,3,0,0" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Grid Margin="0,0,12,0" VerticalAlignment="Center">
                        <Button x:Name="NotificationsButtonGeneric"
                                Command="{Binding ToggleNotificationsCommand}"
                                Style="{StaticResource TextButtonStyle}"
                                Width="38"
                                Height="38"
                                Padding="0"
                                ToolTip="Notifications"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <TextBlock Text="&#xF2A3;"
                                           FontFamily="Segoe Fluent Icons"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <Border Background="{StaticResource DangerBrush}"
                                        CornerRadius="7"
                                        MinWidth="14"
                                        Height="14"
                                        Padding="3,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding UnreadNotificationText}"
                                               Foreground="{StaticResource TextInvertedBrush}"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Button>

                        <Popup IsOpen="{Binding IsNotificationPanelOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=NotificationsButtonGeneric}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <Border Style="{StaticResource StudentDashboardPopupBorderStyle}"
                                    MaxHeight="430"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="14"
                                    Margin="0,8,0,0">
                                <DockPanel LastChildFill="True">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <TextBlock Text="Notifications"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   DockPanel.Dock="Left" />
                                        <Button Content="Mark all read"
                                                Command="{Binding MarkNotificationsReadCommand}"
                                                Style="{StaticResource TextButtonStyle}"
                                                HorizontalAlignment="Right"
                                                DockPanel.Dock="Right" />
                                    </DockPanel>

                                    <TextBlock Text="No notifications"
                                               Style="{StaticResource CaptionText}"
                                               Visibility="{Binding HasNotifications, Converter={StaticResource InverseBoolToVisibility}}"
                                               Margin="0,6,0,0" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl ItemsSource="{Binding Notifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,0,0,10"
                                                            Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           DockPanel.Dock="Left" />
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd MMM HH:mm}}"
                                                                           Style="{StaticResource CaptionText}"
                                                                           DockPanel.Dock="Right" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding Message}"
                                                                       Style="{StaticResource CaptionText}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <controls:StatusBadge Status="{Binding RoleText}" Text="{Binding RoleText}" Margin="0,0,12,0" />
                    <Border Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentUserName}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="180" />
                            <TextBlock Text="Signed in"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Button Content="Logout"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Sign out of Dormitory Management" />
                </StackPanel>
            </DockPanel>
        </Border>
        <Border Background="{StaticResource StudentDashboardSurfaceBrush}"
                BorderBrush="{StaticResource StudentDashboardSurfaceHighestBrush}"
                BorderThickness="0,0,0,1"
                Height="{StaticResource StudentDashboardHeaderMinHeight}"
                Visibility="{Binding IsSharedTopBarChrome, Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <effects:DropShadowEffect BlurRadius="3"
                                          ShadowDepth="1"
                                          Opacity="0.05"
                                          Color="#000000" />
            </Border.Effect>
            <Grid Margin="{StaticResource StudentDashboardHeaderOuterPadding}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="OfficeBuildingOutline"
                                                Width="28"
                                                Height="28"
                                                Margin="0,0,8,0"
                                                Foreground="{StaticResource StudentDashboardPrimaryContainerBrush}"
                                                VerticalAlignment="Center" />

                    <TextBlock Text="DormManagement"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource StudentDashboardPrimaryContainerBrush}"
                               FontFamily="{StaticResource StudentDashboardHeadlineFontFamily}"
                               FontWeight="Bold"
                               FontSize="18" />
                </StackPanel>

                <Grid Grid.Column="1"
                      Margin="{StaticResource StudentDashboardHeaderNavMargin}"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Tickets"
                            Style="{StaticResource StudentDashboardPrimaryCtaButtonStyle}"
                            Margin="0,0,12,0"
                            MinHeight="0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus"
                                                        Width="14"
                                                        Height="14"
                                                        Margin="0,0,8,0"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="New Ticket"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Grid Margin="0,0,10,0">
                        <Button x:Name="NotificationsButtonStudent"
                                Command="{Binding ToggleNotificationsCommand}"
                                Style="{StaticResource StudentDashboardHeaderIconButtonStyle}"
                                ToolTip="Notifications">
                            <iconPacks:PackIconMaterial Kind="BellOutline"
                                                        Width="18"
                                                        Height="18"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center" />
                        </Button>
                        <Border Width="8"
                                Height="8"
                                Background="{StaticResource StudentDashboardErrorBrush}"
                                BorderBrush="{StaticResource StudentDashboardSurfaceBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,9,9,0"
                                Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVisibility}}" />

                        <Popup IsOpen="{Binding IsNotificationPanelOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=NotificationsButtonStudent}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <Border Style="{StaticResource StudentDashboardPopupBorderStyle}">
                                <DockPanel LastChildFill="True">
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                        <TextBlock Text="Notifications"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="{StaticResource StudentDashboardTextPrimaryBrush}"
                                                   DockPanel.Dock="Left" />
                                        <Button Content="Mark all read"
                                                Command="{Binding MarkNotificationsReadCommand}"
                                                Style="{StaticResource TextButtonStyle}"
                                                HorizontalAlignment="Right"
                                                DockPanel.Dock="Right" />
                                    </DockPanel>

                                    <TextBlock Text="No notifications"
                                               Style="{StaticResource CaptionText}"
                                               Visibility="{Binding HasNotifications, Converter={StaticResource InverseBoolToVisibility}}"
                                               Margin="0,6,0,0" />

                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl ItemsSource="{Binding Notifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource StudentDashboardSurfaceHighestBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="0,0,0,10"
                                                            Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource StudentDashboardTextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           DockPanel.Dock="Left" />
                                                                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd MMM HH:mm}}"
                                                                           Style="{StaticResource CaptionText}"
                                                                           DockPanel.Dock="Right" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding Message}"
                                                                       Style="{StaticResource CaptionText}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <Button Style="{StaticResource StudentDashboardHeaderIconButtonStyle}"
                            ToolTip="Settings unavailable"
                            Cursor="Arrow"
                            Margin="0,0,0,0">
                        <iconPacks:PackIconMaterial Kind="CogOutline"
                                                    Width="18"
                                                    Height="18"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center" />
                    </Button>

                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="StudentProfile"
                            ToolTip="Hồ sơ cá nhân"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="12,0,0,0">
                        <Ellipse Width="36"
                                 Height="36"
                                 Stroke="{StaticResource StudentDashboardSurfaceHighestBrush}"
                                 StrokeThickness="2">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="pack://application:,,,/DormitoryManagement.WPF;component/Assets/Images/ForumHome/forum-home-avatar-student.png"
                                            Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>




















