<UserControl x:Class="DormitoryManagement.WPF.Views.Forum.ForumHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/DormitoryManagement.WPF;component/Resources/Converters.xaml" />
                <ResourceDictionary Source="/DormitoryManagement.WPF;component/Resources/ForumHome.xaml" />
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ForumHomeTopNavButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="Margin" Value="0,0,14,0" />
                <Setter Property="Padding" Value="8,0" />
                <Setter Property="Width" Value="36" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextSecondaryBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Border x:Name="ActiveUnderline"
                                        Width="20"
                                        Height="2"
                                        VerticalAlignment="Bottom"
                                        CornerRadius="1"
                                        Background="{StaticResource ForumHomePrimaryBrush}"
                                        Visibility="Collapsed" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                    <Setter TargetName="ActiveUnderline" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ForumHomeRailButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="Padding" Value="12,12,14,12" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="Indicator"
                                        Width="4"
                                        Margin="0,4,0,4"
                                        HorizontalAlignment="Left"
                                        Background="{StaticResource ForumHomePrimaryBrush}"
                                        CornerRadius="2"
                                        Visibility="Collapsed" />
                                <Border x:Name="Chrome"
                                        Margin="8,0,0,0"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="{StaticResource ForumHomeControlCornerRadius}">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True" />
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ForumHomePrimarySubtleBrush}" />
                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ForumHomeShortcutButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="Padding" Value="8,8,12,8" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="{StaticResource ForumHomePrimarySubtleBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ForumHomeIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomeOutlineBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="ForumHomeComposeTagButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="Margin" Value="0,0,8,8" />
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Background" Value="#FFF3F4F6" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="999"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ForumHomePrimarySubtleBrush}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource ForumHomePrimaryContainerBrush}" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ForumHomeHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceContainerBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ForumHomeEmbeddedActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ForumHomeCanvasBrush}"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True"
          TextOptions.TextFormattingMode="Ideal"
          TextOptions.TextHintingMode="Fixed"
          TextOptions.TextRenderingMode="ClearType">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>




        <ItemsControl Grid.RowSpan="2"
                      Panel.ZIndex="20"
                      ItemsSource="{Binding PreviewPanels}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,92,32,0"
                      Visibility="{Binding ShowPreviewPanels, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ForumHomeDropdownBorderStyle}"
                            Width="320"
                            Margin="0,0,0,12"
                            Visibility="{Binding IsOpen, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding Title}"
                                               Style="{StaticResource ForumHomeHeadlineTextStyle}" />
                                    <TextBlock Text="Xem trước cục bộ"
                                               Style="{StaticResource ForumHomeMetaTextStyle}" />
                                </StackPanel>
                                <Button Style="{StaticResource ForumHomeIconButtonStyle}"
                                        Width="32"
                                        Height="32"
                                        Command="{Binding DataContext.ClosePreviewPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        DockPanel.Dock="Right">
                                    <iconPacks:PackIconMaterial Kind="Close"
                                                                Width="16"
                                                                Height="16"
                                                                Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                                </Button>
                            </DockPanel>

                            <ItemsControl ItemsSource="{Binding Items}"
                                          Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ForumHomeSurfaceLowBrush}"
                                                BorderBrush="{StaticResource ForumHomeSurfaceHighBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Border Width="8"
                                                            Height="8"
                                                            CornerRadius="4"
                                                            Background="{StaticResource ForumHomePrimaryBrush}"
                                                            Margin="0,6,8,0"
                                                            DockPanel.Dock="Left"
                                                            Visibility="{Binding IsUnread, Converter={StaticResource BoolToVisibility}}" />
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource ForumHomeBodyTextStyle}"
                                                               FontWeight="SemiBold" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource ForumHomeMetaTextStyle}"
                                                           Margin="0,6,0,0" />
                                                <TextBlock Text="{Binding MetaText}"
                                                           Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                           Margin="0,8,0,0"
                                                           Visibility="{Binding MetaText, Converter={StaticResource StringToVisibility}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{StaticResource ForumHomeSurfaceLowBrush}"
                                    CornerRadius="14"
                                    Padding="14"
                                    Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVisibility}}">
                                <TextBlock Text="{Binding EmptyStateText}"
                                           Style="{StaticResource ForumHomeMetaTextStyle}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border Grid.Row="0"
                Background="{StaticResource ForumHomeSurfaceBrush}"
                BorderBrush="{StaticResource ForumHomeOutlineBrush}"
                BorderThickness="0,0,0,1"
                Height="{StaticResource ForumHomeHeaderHeight}"
                Padding="32,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding BrandText}"
                               Style="{StaticResource ForumHomeBrandTextStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,32,0" />

                    <ItemsControl ItemsSource="{Binding TopNavItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ForumHomeTopNavButtonStyle}"
                                        Command="{Binding DataContext.SelectTopNavCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding Label}">
                                    <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                                Width="18"
                                                                Height="18"
                                                                Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Center"
                      MaxWidth="576"
                      Margin="48,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ForumHomeTextBoxStyle}"
                             Padding="40,8,16,8"
                             VerticalContentAlignment="Center"
                             MinWidth="360" />
                    <iconPacks:PackIconMaterial Kind="Magnify"
                                                Width="18"
                                                Height="18"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                    <TextBlock Text="{Binding SearchPlaceholder}"
                               Style="{StaticResource ForumHomeMetaTextStyle}"
                               IsHitTestVisible="False"
                               Margin="40,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasSearchInput, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,8,0">
                        <Button Style="{StaticResource ForumHomeHeaderActionButtonStyle}"
                                Command="{Binding OpenMessagesCommand}">
                            <iconPacks:PackIconMaterial Kind="MessageOutline"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                        </Button>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource ForumHomePrimaryBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,10,10,0" />
                    </Grid>
                    <Grid Margin="0,0,12,0">
                        <Button Style="{StaticResource ForumHomeHeaderActionButtonStyle}"
                                Command="{Binding OpenNotificationCenterCommand}">
                            <iconPacks:PackIconMaterial Kind="BellOutline"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                        </Button>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource ForumHomePrimaryBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,10,10,0" />
                    </Grid>
                    <Border BorderBrush="{StaticResource ForumHomeSurfaceContainerBrush}"
                            BorderThickness="1,0,0,0"
                            Padding="16,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="20"
                                    Background="{StaticResource ForumHomeSurfaceHighestBrush}"
                                    BorderBrush="{StaticResource ForumHomeSurfaceContainerBrush}"
                                    BorderThickness="1">
                                <Border.Clip>
                                    <EllipseGeometry Center="20,20"
                                                     RadiusX="20"
                                                     RadiusY="20" />
                                </Border.Clip>
                                <Image Source="{Binding HeaderUserSummary.AvatarAssetPath}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HeaderUserSummary.DisplayName}"
                                           Style="{StaticResource ForumHomeLabelMediumTextStyle}" />
                                <TextBlock Text="{Binding HeaderUserSummary.RoomLabel}"
                                           Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                           Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                            </StackPanel>
                            <iconPacks:PackIconMaterial Kind="ChevronDown"
                                                        Width="16"
                                                        Height="16"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="32,24,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="DANH MỤC"
                                   Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                   Margin="4,0,0,8" />
                        <ItemsControl ItemsSource="{Binding CategoryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ForumHomeRailButtonStyle}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Margin="0,2,10,0"
                                                                        VerticalAlignment="Top"
                                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Label}"
                                                       Style="{StaticResource ForumHomeLabelMediumTextStyle}"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="THẺ PHỔ BIẾN"
                                   Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                   Margin="4,0,0,8" />
                        <ItemsControl ItemsSource="{Binding TagChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ForumHomePopularTagButtonStyle}"
                                            Margin="0,0,8,8"
                                            Command="{Binding DataContext.SelectTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel>
                        <DockPanel Margin="4,0,0,8" LastChildFill="False">
                            <TextBlock Text="KHU VỰC"
                                       Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                       DockPanel.Dock="Left" />
                            <iconPacks:PackIconMaterial Kind="ArrowRight"
                                                        Width="16"
                                                        Height="16"
                                                        DockPanel.Dock="Right"
                                                        Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding AreaShortcuts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ForumHomeShortcutButtonStyle}"
                                            Command="{Binding DataContext.SelectAreaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32"
                                                    Height="32"
                                                    CornerRadius="8"
                                                    Background="{StaticResource ForumHomeSurfaceHighestBrush}">
                                                <TextBlock Text="{Binding BadgeText}"
                                                           Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       Style="{StaticResource ForumHomeLabelMediumTextStyle}"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource ForumHomeCardBorderStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="20"
                                    Background="{StaticResource ForumHomeSurfaceHighestBrush}"
                                    BorderBrush="{StaticResource ForumHomeSurfaceContainerBrush}"
                                    BorderThickness="1">
                                <Border.Clip>
                                    <EllipseGeometry Center="20,20"
                                                     RadiusX="20"
                                                     RadiusY="20" />
                                </Border.Clip>
                                <Image Source="{Binding HeaderUserSummary.AvatarAssetPath}"
                                       Stretch="UniformToFill" />
                            </Border>
                            <Button Grid.Column="2"
                                    Style="{StaticResource ForumHomeEmbeddedActionButtonStyle}"
                                    Command="{Binding ComposeCommand}"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center">
                                <Border Background="{StaticResource ForumHomeSurfaceLowBrush}"
                                        CornerRadius="{StaticResource ForumHomeControlCornerRadius}"
                                        Padding="16,8">
                                    <TextBlock Text="{Binding ComposePrompt}"
                                               Style="{StaticResource ForumHomeMetaTextStyle}" />
                                </Border>
                            </Button>
                            <Button Grid.Column="3"
                                    Content="Đăng bài"
                                    Style="{StaticResource ForumHomePrimaryButtonStyle}"
                                    Padding="24,8"
                                    Command="{Binding ComposeCommand}" />
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource ForumHomeMetaTextStyle}"
                               Margin="4,0,0,12"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}" />

                    <Border Style="{StaticResource ForumHomeCardBorderStyle}"
                            Padding="16,14"
                            Margin="0,0,0,16"
                            Visibility="{Binding ShowFilterSummary, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Margin="0,0,12,0">
                                <TextBlock Text="Bộ lọc xem trước đang bật"
                                           Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                           Foreground="{StaticResource ForumHomePrimaryBrush}" />
                                <TextBlock Text="Kết quả hiện chỉ thay đổi trong bản xem trước cục bộ."
                                           Style="{StaticResource ForumHomeMetaTextStyle}" />
                            </StackPanel>
                            <Button Content="Xóa bộ lọc"
                                    Style="{StaticResource ForumHomeSecondaryButtonStyle}"
                                    Command="{Binding ResetFiltersCommand}"
                                    DockPanel.Dock="Right"
                                    VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource ForumHomeEmptyStateBorderStyle}"
                            Margin="0,0,0,16"
                            Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="56"
                                    Height="56"
                                    CornerRadius="28"
                                    Background="{StaticResource ForumHomeSurfaceLowBrush}"
                                    HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="Magnify"
                                                            Width="26"
                                                            Height="26"
                                                            Foreground="{StaticResource ForumHomePrimaryBrush}"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Không tìm thấy bài viết phù hợp."
                                       Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                       Margin="0,16,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Text="Hãy xóa bớt bộ lọc hoặc thử lại với từ khóa ngắn hơn trong bản xem trước."
                                       Style="{StaticResource ForumHomeMetaTextStyle}"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       MaxWidth="360" />
                            <Button Content="Xem lại toàn bộ bài viết"
                                    Style="{StaticResource ForumHomePrimaryButtonStyle}"
                                    Command="{Binding ResetFiltersCommand}"
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding FeedCards}"
                                  Visibility="{Binding ShowEmptyState, Converter={StaticResource InverseBoolToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ForumHomeFeaturedBorderStyle}"
                                        Padding="20,18,20,16"
                                        Margin="0,0,0,16"
                                        Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.OpenPostDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>




                                        <Grid Grid.Row="0" Margin="0,0,0,14">
                                            <ItemsControl ItemsSource="{Binding Badges}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="10,4"
                                                                Margin="0,0,8,0"
                                                                CornerRadius="{StaticResource ForumHomePillCornerRadius}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Tone}" Value="primary">
                                                                            <Setter Property="Background" Value="#FFF5E8" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Tone}" Value="secondary">
                                                                            <Setter Property="Background" Value="#F0EEFF" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Tone}" Value="tertiary">
                                                                            <Setter Property="Background" Value="#E7FAF2" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Text}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ForumHomeSectionLabelTextStyle}">
                                                                        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Tone}" Value="primary">
                                                                                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Tone}" Value="secondary">
                                                                                <Setter Property="Foreground" Value="{StaticResource ForumHomeSecondaryBrush}" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Tone}" Value="tertiary">
                                                                                <Setter Property="Foreground" Value="{StaticResource ForumHomeTertiaryContainerBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                        <Button Width="24"
                                                Height="24"
                                                Padding="0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.ToggleLikeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ForumHomeHeaderActionButtonStyle}">
                                            <iconPacks:PackIconMaterial Width="18"
                                                                        Height="18">
                                                <iconPacks:PackIconMaterial.Style>
                                                    <Style TargetType="iconPacks:PackIconMaterial">
                                                        <Setter Property="Kind" Value="HeartOutline" />
                                                        <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                                <Setter Property="Kind" Value="Heart" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </iconPacks:PackIconMaterial.Style>
                                            </iconPacks:PackIconMaterial>
                                        </Button>

                                        <TextBlock Grid.Row="1"
                                                    Text="{Binding Title}"
                                                    Style="{StaticResource ForumHomeHeadlineMediumTextStyle}"
                                                    TextWrapping="Wrap"
                                                    Margin="0,0,0,10"
                                                    MaxHeight="64" />

                                        <TextBlock Grid.Row="2"
                                                    Text="{Binding Excerpt}"
                                                    Style="{StaticResource ForumHomeMetaTextStyle}"
                                                    TextWrapping="Wrap"
                                                    Margin="0,0,0,16"
                                                    MaxHeight="44" />

                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="28"
                                                        Height="28"
                                                        CornerRadius="14"
                                                        Background="{StaticResource ForumHomeSurfaceHighestBrush}"
                                                        BorderBrush="{StaticResource ForumHomeSurfaceContainerBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Center">
                                                    <Border.Clip>
                                                        <EllipseGeometry Center="14,14"
                                                                         RadiusX="14"
                                                                         RadiusY="14" />
                                                    </Border.Clip>
                                                    <Grid>
                                                        <Image Source="{Binding AuthorAvatarAssetPath}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding AuthorAvatarAssetPath, Converter={StaticResource StringToVisibility}}" />
                                                        <TextBlock Text="{Binding AuthorAvatarLabel}"
                                                                   Foreground="{StaticResource ForumHomePrimaryBrush}"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding AuthorAvatarAssetPath, Converter={StaticResource EmptyStringToVisibility}}" />
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AuthorName}"
                                                               Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                               Foreground="{StaticResource ForumHomeTextPrimaryBrush}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding RelativeTimeText}"
                                                               Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                               Foreground="{StaticResource ForumHomeTextSecondaryBrush}"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <iconPacks:PackIconMaterial Kind="EyeOutline"
                                                                                Width="14"
                                                                                Height="14"
                                                                                Margin="0,1,4,0"
                                                                                Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding ViewCountText}"
                                                               Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                               Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <iconPacks:PackIconMaterial Kind="HeartOutline"
                                                                                Width="14"
                                                                                Height="14"
                                                                                Margin="0,1,4,0"
                                                                                Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding LikeCountText}"
                                                               Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                               Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="MessageOutline"
                                                                                Width="14"
                                                                                Height="14"
                                                                                Margin="0,1,4,0"
                                                                                Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                    <TextBlock Text="{Binding CommentCountText}"
                                                               Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                               Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource ForumHomeCardBorderStyle}" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16" LastChildFill="False">
                                <TextBlock Text="Hoạt động SV"
                                           Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                           DockPanel.Dock="Left" />
                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Right"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource ForumHomePrimaryButtonStyle}"
                                            Padding="14,6"
                                            MinHeight="32"
                                            Margin="0,0,10,0"
                                            Command="{Binding OpenActivityQuickAddCommand}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <iconPacks:PackIconMaterial Grid.Column="0"
                                                                        Kind="Plus"
                                                                        Width="14"
                                                                        Height="14"
                                                                        Margin="0,0,6,0"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="{StaticResource ForumHomeWhiteBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="Thêm"
                                                       VerticalAlignment="Center"
                                                       FontFamily="{StaticResource ForumHomeBodyFontFamily}"
                                                       FontSize="{StaticResource ForumHomeLabelMediumSize}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ForumHomeWhiteBrush}" />
                                        </Grid>
                                    </Button>
                                    <iconPacks:PackIconMaterial Kind="ArrowRight"
                                                                Width="18"
                                                                Height="18"
                                                                VerticalAlignment="Center"
                                                                Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                </StackPanel>
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding ActivityItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource ForumHomeOutlineBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,0,0,18"
                                                Margin="0,0,0,18">
                                            <Button Style="{StaticResource ForumHomeEmbeddedActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenActivityPreviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="48"
                                                            Height="56"
                                                            CornerRadius="{StaticResource ForumHomeControlCornerRadius}"
                                                            Background="{StaticResource ForumHomeSurfaceHighestBrush}"
                                                            BorderThickness="0,0,0,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AccentTone}" Value="secondary">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSecondaryBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding AccentTone}" Value="primary">
                                                                        <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding MonthText}"
                                                                       Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                                       HorizontalAlignment="Center" />
                                                            <TextBlock Text="{Binding DayText}"
                                                                       Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                                                       FontSize="16"
                                                                       HorizontalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource ForumHomeLabelMediumTextStyle}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <iconPacks:PackIconMaterial Kind="MapMarkerOutline"
                                                                                        Width="14"
                                                                                        Height="14"
                                                                                        Margin="0,1,6,0"
                                                                                        Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                       Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                                       Foreground="{StaticResource ForumHomeTextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       TextWrapping="NoWrap" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ForumHomeCardBorderStyle}" Padding="20">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,16" LastChildFill="False">
                                <TextBlock Text="Liên hệ khẩn cấp"
                                           Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                           DockPanel.Dock="Left" />
                                <iconPacks:PackIconMaterial Kind="ArrowRight"
                                                            Width="18"
                                                            Height="18"
                                                            DockPanel.Dock="Right"
                                                            VerticalAlignment="Center"
                                                            Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding EmergencyContacts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,0,0,12"
                                                Margin="0,0,0,12">
                                            <Button Style="{StaticResource ForumHomeEmbeddedActionButtonStyle}"
                                                    Command="{Binding DataContext.OpenEmergencyContactPreviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="56" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="48"
                                                            Height="48"
                                                            CornerRadius="{StaticResource ForumHomeControlCornerRadius}"
                                                            Background="{StaticResource ForumHomeSurfaceHighestBrush}">
                                                        <iconPacks:PackIconMaterial Kind="{Binding IconKind}"
                                                                                    Width="20"
                                                                                    Height="20"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center">
                                                            <iconPacks:PackIconMaterial.Style>
                                                                <Style TargetType="iconPacks:PackIconMaterial">
                                                                    <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding AccentTone}" Value="secondary">
                                                                            <Setter Property="Foreground" Value="{StaticResource ForumHomeSecondaryBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding AccentTone}" Value="tertiary">
                                                                            <Setter Property="Foreground" Value="{StaticResource ForumHomeDangerBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </iconPacks:PackIconMaterial.Style>
                                                        </iconPacks:PackIconMaterial>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource ForumHomeLabelMediumTextStyle}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap" />
                                                        <TextBlock Text="{Binding ContactText}"
                                                                   Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                                   Foreground="{StaticResource ForumHomeTextSecondaryBrush}"
                                                                   Margin="0,2,0,0" />
                                                    </StackPanel>
                                                    <iconPacks:PackIconMaterial Grid.Column="2"
                                                                                Kind="PhoneOutline"
                                                                                Width="20"
                                                                                Height="20"
                                                                                Margin="12,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                </Grid>
                                            </Button>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{StaticResource ForumHomeSurfaceBrush}"
                                    BorderBrush="{StaticResource ForumHomeOutlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="16"
                                    Margin="0,4,0,0"
                                    Visibility="{Binding ShowEmergencyContactPreview, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="Xem trước liên hệ khẩn cấp"
                                                   Style="{StaticResource ForumHomeSectionLabelTextStyle}"
                                                   Foreground="{StaticResource ForumHomePrimaryBrush}"
                                                   DockPanel.Dock="Left" />
                                        <Button Style="{StaticResource ForumHomeIconButtonStyle}"
                                                Width="32"
                                                Height="32"
                                                Command="{Binding DismissEmergencyContactPreviewCommand}"
                                                DockPanel.Dock="Right">
                                            <iconPacks:PackIconMaterial Kind="Close"
                                                                        Width="16"
                                                                        Height="16"
                                                                        Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                                        </Button>
                                    </DockPanel>
                                    <TextBlock Text="{Binding SelectedEmergencyContact.Title}"
                                               Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding SelectedEmergencyContact.ContactText}"
                                               Style="{StaticResource ForumHomeBodyTextStyle}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedEmergencyContact.PreviewDialState}"
                                               Style="{StaticResource ForumHomeMetaTextStyle}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Bản xem trước chỉ mô phỏng thao tác liên hệ, không thực hiện cuộc gọi thật."
                                               Style="{StaticResource ForumHomeMetaTextStyle}"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="40"
              Background="#66000000"
              Visibility="{Binding ShowComposeDialog, Converter={StaticResource BoolToVisibility}}">
            <Border Width="664"
                    MaxWidth="664"
                    Background="{StaticResource ForumHomeSurfaceBrush}"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ForumHomeCardHoverShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="24,20"
                            BorderBrush="{StaticResource ForumHomeSurfaceLowBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{Binding ComposeDialogTitle}"
                                       Style="{StaticResource ForumHomeHeadlineTextStyle}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       DockPanel.Dock="Left" />
                            <Button Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding CloseComposeDialogCommand}"
                                    DockPanel.Dock="Right">
                                <iconPacks:PackIconMaterial Kind="Close"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                            </Button>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="520"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,20,24,20">
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="248" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ComposeTitleLabel}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,8" />
                                    <ui:TextBox Text="{Binding ComposeTitleText, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{Binding ComposeTitlePlaceholder}"
                                                Height="43"
                                                Padding="16,10"
                                                FontFamily="{StaticResource ForumHomeBodyFontFamily}"
                                                FontSize="14" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding ComposeCategoryLabel}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding ComposeCategoryItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource ForumHomeComposeTagButtonStyle}"
                                                    Command="{Binding DataContext.ToggleComposeTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Text}" FontSize="12" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="White" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="  ✓" FontSize="12" FontWeight="Medium" Foreground="White">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Button>                                        </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="{Binding ComposeContentLabel}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,8" />
                                <Grid>
                                    <Border Background="{StaticResource ForumHomeSurfaceBrush}" BorderBrush="{StaticResource ForumHomeSurfaceHighBrush}" BorderThickness="1" CornerRadius="8" />
                                    <ui:TextBox Text="{Binding ComposeDraftText, UpdateSourceTrigger=PropertyChanged}"
                                                PlaceholderText="{Binding ComposeContentPlaceholder}"
                                                MinHeight="112"
                                                Padding="16,12"
                                                AcceptsReturn="True"
                                                TextWrapping="Wrap"
                                                VerticalScrollBarVisibility="Auto"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontFamily="{StaticResource ForumHomeBodyFontFamily}"
                                                FontSize="14"
                                                Foreground="{StaticResource ForumHomeTextPrimaryBrush}"
                                                TextOptions.TextFormattingMode="Ideal"
                                                TextOptions.TextHintingMode="Fixed"
                                                TextOptions.TextRenderingMode="ClearType" />
                                </Grid>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="{Binding ComposeCustomTagsLabel}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Margin="0,0,0,8" />
                                <ui:TextBox Text="{Binding ComposeCustomTagsText, UpdateSourceTrigger=PropertyChanged}"
                                            PlaceholderText="{Binding ComposeCustomTagsPlaceholder}"
                                            Height="43"
                                            Padding="16,10"
                                            FontFamily="{StaticResource ForumHomeBodyFontFamily}"
                                            FontSize="14"
                                            Margin="0,0,0,12" />
                                <ItemsControl ItemsSource="{Binding ComposeTagChips}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ForumHomeComposeTagButtonStyle}"
                                                    Command="{Binding DataContext.ToggleComposeTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Text}" FontSize="12" FontWeight="Medium">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextSecondaryBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="White" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                        </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="#FFF9FAFB"
                            BorderBrush="{StaticResource ForumHomeSurfaceLowBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="24,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="Hủy"
                                       Margin="0,0,12,0"
                                       Background="{StaticResource ForumHomeSurfaceBrush}"
                                       BorderBrush="{StaticResource ForumHomeSurfaceHighBrush}"
                                       Foreground="{StaticResource ForumHomePrimaryBrush}"
                                       Padding="20,10"
                                       Appearance="Secondary"
                                       Command="{Binding CloseComposeDialogCommand}" />
                            <ui:Button Content="Đăng bài ngay"
                                       Padding="28,10"
                                       Background="{StaticResource ForumHomePrimaryContainerBrush}"
                                       BorderBrush="{StaticResource ForumHomePrimaryContainerBrush}"
                                       Foreground="{StaticResource ForumHomeWhiteBrush}"
                                       FontWeight="Bold"
                                       Appearance="Primary"
                                       Command="{Binding SubmitComposePreviewCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- Activity popup contract: Create New Activity | Cancel | Create Activity -->
        <Grid Grid.RowSpan="2"
              Panel.ZIndex="41"
              Background="#66000000"
              Visibility="{Binding ShowActivityDialog, Converter={StaticResource BoolToVisibility}}">
            <Border Width="664"
                    MaxWidth="664"
                    Background="{StaticResource ForumHomeSurfaceBrush}"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Effect="{StaticResource ForumHomeCardHoverShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            Padding="24,20"
                            BorderBrush="{StaticResource ForumHomeSurfaceLowBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="36" Height="36" Margin="0,0,12,0" CornerRadius="18" Background="{StaticResource ForumHomePrimarySubtleBrush}">
                                    <iconPacks:PackIconMaterial Kind="PlusCircleOutline" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ForumHomePrimaryBrush}" />
                                </Border>
                                <TextBlock Text="{Binding ActivityDialogTitle}" Style="{StaticResource ForumHomeHeadlineTextStyle}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Command="{Binding CloseActivityDialogCommand}" DockPanel.Dock="Right">
                                <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ForumHomeTextMutedBrush}" />
                            </Button>
                        </DockPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" MaxHeight="520" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,20,24,20">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Margin="0,0,0,8" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityNameLabel}" />
                                <ui:TextBox Text="{Binding ActivityNameText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding ActivityNamePlaceholder}" Height="43" Padding="16,10" FontFamily="{StaticResource ForumHomeBodyFontFamily}" FontSize="14" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ForumHomeDangerBrush}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityNameError}" Visibility="{Binding ActivityNameError, Converter={StaticResource StringToVisibility}}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Margin="0,0,0,8" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityCategoryLabel}" />
                                <ItemsControl ItemsSource="{Binding ActivityCategoryOptions}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,8,8" Padding="14,8" Style="{StaticResource ForumHomePopularTagButtonStyle}" Command="{Binding DataContext.SelectActivityCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="{Binding IconKind}" Width="14" Height="14" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding Label}" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ForumHomeDangerBrush}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityCategoryError}" Visibility="{Binding ActivityCategoryError, Converter={StaticResource StringToVisibility}}" />
                            </StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="0,0,0,8" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityDateLabel}" />
                                    <ui:TextBox Text="{Binding ActivityDateText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="YYYY-MM-DD" Height="43" Padding="16,10" FontFamily="{StaticResource ForumHomeBodyFontFamily}" FontSize="14" />
                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ForumHomeDangerBrush}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityDateError}" Visibility="{Binding ActivityDateError, Converter={StaticResource StringToVisibility}}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,8" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityTimeLabel}" />
                                    <ui:TextBox Text="{Binding ActivityTimeText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="HH:MM" Height="43" Padding="16,10" FontFamily="{StaticResource ForumHomeBodyFontFamily}" FontSize="14" />
                                    <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ForumHomeDangerBrush}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityTimeError}" Visibility="{Binding ActivityTimeError, Converter={StaticResource StringToVisibility}}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Margin="0,0,0,8" Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityLocationLabel}" />
                                <ui:TextBox Text="{Binding ActivityLocationText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding ActivityLocationPlaceholder}" Height="43" Padding="16,10" FontFamily="{StaticResource ForumHomeBodyFontFamily}" FontSize="14" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource ForumHomeDangerBrush}" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityLocationError}" Visibility="{Binding ActivityLocationError, Converter={StaticResource StringToVisibility}}" />
                            </StackPanel>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Style="{StaticResource ForumHomeSectionLabelTextStyle}" FontWeight="Bold" Text="{Binding ActivityDescriptionLabel}" />
                                    <TextBlock Margin="6,0,0,0" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Text="{Binding ActivityDescriptionOptionalText}" />
                                </StackPanel>
                                <ui:TextBox Text="{Binding ActivityDescriptionText, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding ActivityDescriptionPlaceholder}" MinHeight="112" Padding="16,12" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="{StaticResource ForumHomeBodyFontFamily}" FontSize="14" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="2" Background="#FFF9FAFB" BorderBrush="{StaticResource ForumHomeSurfaceLowBrush}" BorderThickness="0,1,0,0" Padding="24,16">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Style="{StaticResource ForumHomeSectionLabelTextStyle}" Foreground="{StaticResource ForumHomeDangerBrush}" Text="{Binding ActivityValidationSummary}" Visibility="{Binding ActivityValidationSummary, Converter={StaticResource StringToVisibility}}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <ui:Button Content="{Binding ActivitySecondaryActionText}" Margin="0,0,12,0" Background="{StaticResource ForumHomeSurfaceBrush}" BorderBrush="{StaticResource ForumHomeSurfaceHighBrush}" Foreground="{StaticResource ForumHomePrimaryBrush}" Padding="20,10" Appearance="Secondary" Command="{Binding CloseActivityDialogCommand}" />
                                <ui:Button Content="{Binding ActivityPrimaryActionText}" Padding="28,10" Background="{StaticResource ForumHomePrimaryContainerBrush}" BorderBrush="{StaticResource ForumHomePrimaryContainerBrush}" Foreground="{StaticResource ForumHomeWhiteBrush}" FontWeight="Bold" Appearance="Primary" Command="{Binding SubmitActivityPreviewCommand}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>    </Grid>
</UserControl>














