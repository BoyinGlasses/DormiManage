<UserControl x:Class="DormitoryManagement.WPF.Views.Dashboard.StudentDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             Loaded="OnLoaded">
    <Grid Background="{StaticResource StudentDashboardCanvasBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,24" MaxWidth="1152" HorizontalAlignment="Center">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel MaxWidth="720" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding GreetingHeadline}"
                                   Style="{StaticResource StudentDashboardGreetingTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,2" />
                        <TextBlock Text="{Binding GreetingSupportingText}"
                                   Style="{StaticResource StudentDashboardSupportingTextStyle}"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource StudentDashboardRefreshButtonStyle}"
                            Margin="{StaticResource StudentDashboardRefreshMargin}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh"
                                                        Width="18"
                                                        Height="18"
                                                        Margin="{StaticResource StudentDashboardRefreshIconMargin}"
                                                        VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RefreshButtonText}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <controls:ErrorState Title="Could not load dashboard"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,14" />

                <WrapPanel Margin="0,0,-16,0">
                    <Button Command="{Binding OpenRoomRegistrationPopupCommand}"
                            IsEnabled="{Binding CanOpenRoomRegistrationPopup}"
                            Style="{StaticResource StudentDashboardSummaryCardButtonStyle}">
                        <Border Style="{StaticResource StudentDashboardSummaryCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding RoomCardTitle}"
                                               Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                                               DockPanel.Dock="Left" />
                                    <iconPacks:PackIconMaterial Kind="Door"
                                                                Width="18"
                                                                Height="18"
                                                                Margin="0,2,0,0"
                                                                Foreground="{StaticResource StudentDashboardPrimaryContainerBrush}"
                                                                DockPanel.Dock="Right" />
                                </DockPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding RoomDisplayText}"
                                           Style="{StaticResource StudentDashboardMetricValueTextStyle}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap" />
                                <Grid Grid.Row="2" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="AccountGroupOutline"
                                                                    Width="14"
                                                                    Height="14"
                                                                    Foreground="{StaticResource StudentDashboardTextSecondaryBrush}"
                                                                    Margin="0,0,6,0"
                                                                    VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding RoomFooterLabel}"
                                                   Style="{StaticResource StudentDashboardStatusLabelTextStyle}" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            BorderThickness="{StaticResource StudentDashboardCardBorderThicknessValue}"
                                            CornerRadius="{StaticResource StudentDashboardStatusBadgeCornerRadius}"
                                            Padding="{StaticResource StudentDashboardStatusPillPadding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource StudentDashboardBadgeNeutralBackgroundBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardBadgeNeutralBorderBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasPendingRoomRequest}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource StudentDashboardPrimaryContainerTintBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HasAssignedRoom}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource StudentDashboardBadgeSuccessBackgroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardBadgeSuccessBorderBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding RoomFooterText}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource StudentDashboardStatusPillTextStyle}">
                                                    <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPendingRoomRequest}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding HasAssignedRoom}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardBadgeSuccessForegroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                                <TextBlock Grid.Row="3"
                                           Margin="0,10,0,0"
                                           Text="{Binding RoomCardHintText}"
                                           Style="{StaticResource StudentDashboardCardMetaTextStyle}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </Button>

                    <Border Style="{StaticResource StudentDashboardSummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding InvoiceCardTitle}"
                                           Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                                           DockPanel.Dock="Left" />
                                <iconPacks:PackIconMaterial Kind="FileDocumentOutline"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,2,0,0"
                                                            Foreground="{StaticResource StudentDashboardErrorBrush}"
                                                            DockPanel.Dock="Right" />
                            </DockPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding CurrentInvoiceAmountText}"
                                           Style="{StaticResource StudentDashboardMetricValueTextStyle}" />
                                <TextBlock Text="{Binding CurrentInvoiceUnitText}"
                                           Margin="8,10,0,0"
                                           Style="{StaticResource StudentDashboardCardMetaTextStyle}" />
                            </StackPanel>
                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding InvoiceStatusLabel}"
                                           Style="{StaticResource StudentDashboardStatusLabelTextStyle}" />
                                <Border Grid.Column="1"
                                        Background="{StaticResource StudentDashboardBadgeDangerBackgroundBrush}"
                                        BorderBrush="{StaticResource StudentDashboardBadgeDangerBorderBrush}"
                                        BorderThickness="{StaticResource StudentDashboardCardBorderThicknessValue}"
                                        CornerRadius="{StaticResource StudentDashboardStatusBadgeCornerRadius}"
                                        Padding="{StaticResource StudentDashboardStatusPillPadding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="!"
                                                   Margin="0,0,6,0"
                                                   Style="{StaticResource StudentDashboardStatusPillTextStyle}"
                                                   Foreground="{StaticResource StudentDashboardBadgeDangerForegroundBrush}" />
                                        <TextBlock Text="{Binding CurrentInvoiceStatusText}"
                                                   Style="{StaticResource StudentDashboardStatusPillTextStyle}"
                                                   Foreground="{StaticResource StudentDashboardBadgeDangerForegroundBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource StudentDashboardSummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding TicketCardTitle}"
                                           Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                                           DockPanel.Dock="Left" />
                                <iconPacks:PackIconMaterial Kind="Headset"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,2,0,0"
                                                            Foreground="{StaticResource StudentDashboardSecondaryBrush}"
                                                            DockPanel.Dock="Right" />
                            </DockPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                                <TextBlock Text="{Binding SupportTicketCountText}"
                                           Style="{StaticResource StudentDashboardMetricValueTextStyle}" />
                                <TextBlock Text="{Binding SupportTicketStateText}"
                                           Margin="8,12,0,0"
                                           Style="{StaticResource StudentDashboardCardMetaTextStyle}" />
                            </StackPanel>
                            <Button Grid.Row="2"
                                    Command="{Binding CreateTicketCommand}"
                                    Style="{StaticResource StudentDashboardCardInlineActionButtonStyle}"
                                    Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SupportTicketActionText}"
                                               Foreground="{StaticResource StudentDashboardSecondaryBrush}"
                                               Style="{StaticResource StudentDashboardStatusPillTextStyle}" />
                                    <iconPacks:PackIconMaterial Kind="ArrowRight"
                                                                Width="14"
                                                                Height="14"
                                                                Foreground="{StaticResource StudentDashboardSecondaryBrush}"
                                                                Margin="{StaticResource StudentDashboardInlineArrowMargin}"
                                                                VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource StudentDashboardSummaryCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="{Binding VehicleCardTitle}"
                                           Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                                           DockPanel.Dock="Left" />
                                <iconPacks:PackIconMaterial Kind="Bicycle"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,2,0,0"
                                                            Foreground="{StaticResource StudentDashboardTertiaryContainerBrush}"
                                                            DockPanel.Dock="Right" />
                            </DockPanel>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <TextBlock Text="{Binding VehicleDisplayName}"
                                           Style="{StaticResource StudentDashboardMetricValueTextStyle}"
                                           FontSize="22"
                                           LineHeight="26"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding VehiclePlateText}"
                                           Style="{StaticResource StudentDashboardSupportingTextStyle}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding VehicleStatusLabel}"
                                           Style="{StaticResource StudentDashboardStatusLabelTextStyle}" />
                                <Border Grid.Column="1"
                                        Background="{StaticResource StudentDashboardBadgeSuccessBackgroundBrush}"
                                        BorderBrush="{StaticResource StudentDashboardBadgeSuccessBorderBrush}"
                                        BorderThickness="{StaticResource StudentDashboardCardBorderThicknessValue}"
                                        CornerRadius="{StaticResource StudentDashboardStatusBadgeCornerRadius}"
                                        Padding="{StaticResource StudentDashboardStatusPillPadding}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✓"
                                                   Margin="0,0,6,0"
                                                   Style="{StaticResource StudentDashboardStatusPillTextStyle}"
                                                   Foreground="{StaticResource StudentDashboardBadgeSuccessForegroundBrush}" />
                                        <TextBlock Text="{Binding VehicleStatusText}"
                                                   Style="{StaticResource StudentDashboardStatusPillTextStyle}"
                                                   Foreground="{StaticResource StudentDashboardBadgeSuccessForegroundBrush}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </WrapPanel>

                <StackPanel Margin="0,0,0,0">
                    <TextBlock Text="{Binding QuickActionsSectionTitle}"
                               Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                               FontSize="16"
                               Margin="0,0,0,16" />
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding PayInvoiceCommand}"
                                    Style="{StaticResource StudentDashboardQuickActionTileButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="{StaticResource StudentDashboardIconCircleSize}"
                                            Height="{StaticResource StudentDashboardIconCircleSize}"
                                            CornerRadius="28"
                                            Background="{StaticResource StudentDashboardPrimaryContainerTintBrush}"
                                            HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="CreditCardOutline"
                                                                    Width="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Height="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Foreground="{StaticResource StudentDashboardPrimaryContainerBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Thanh toán"
                                               Style="{StaticResource StudentDashboardQuickActionTextStyle}"
                                               Margin="{StaticResource StudentDashboardQuickActionLabelMargin}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding CreateTicketCommand}"
                                    Style="{StaticResource StudentDashboardQuickActionTileButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="{StaticResource StudentDashboardIconCircleSize}"
                                            Height="{StaticResource StudentDashboardIconCircleSize}"
                                            CornerRadius="28"
                                            Background="{StaticResource StudentDashboardSecondaryContainerTintBrush}"
                                            HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="HammerWrench"
                                                                    Width="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Height="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Foreground="{StaticResource StudentDashboardSecondaryContainerBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Báo hỏng"
                                               Style="{StaticResource StudentDashboardQuickActionTextStyle}"
                                               Margin="{StaticResource StudentDashboardQuickActionLabelMargin}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4" Command="{Binding OpenForumCommand}"
                                    Style="{StaticResource StudentDashboardQuickActionTileButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="{StaticResource StudentDashboardIconCircleSize}"
                                            Height="{StaticResource StudentDashboardIconCircleSize}"
                                            CornerRadius="28"
                                            Background="{StaticResource StudentDashboardTertiaryContainerTintBrush}"
                                            HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="ForumOutline"
                                                                    Width="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Height="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Foreground="{StaticResource StudentDashboardTertiaryContainerBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Forum"
                                               Style="{StaticResource StudentDashboardQuickActionTextStyle}"
                                               Margin="{StaticResource StudentDashboardQuickActionLabelMargin}" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="6" Command="{Binding RegisterRoomCommand}"
                                    Style="{StaticResource StudentDashboardQuickActionTileButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="{StaticResource StudentDashboardIconCircleSize}"
                                            Height="{StaticResource StudentDashboardIconCircleSize}"
                                            CornerRadius="28"
                                            Background="{StaticResource StudentDashboardPrimaryTintBrush}"
                                            HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="CalendarOutline"
                                                                    Width="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Height="{StaticResource StudentDashboardQuickActionIconSize}"
                                                                    Foreground="{StaticResource StudentDashboardPrimaryBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Lịch"
                                               Style="{StaticResource StudentDashboardQuickActionTextStyle}"
                                               Margin="{StaticResource StudentDashboardQuickActionLabelMargin}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <Border Background="{StaticResource StudentDashboardPopupOverlayBrush}"
                Visibility="{Binding IsRoomRegistrationPopupOpen, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Border Style="{StaticResource StudentDashboardPopupBorderStyle}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="32,24,32,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Đăng ký phòng mới"
                                           Style="{StaticResource StudentDashboardCardTitleTextStyle}"
                                           FontSize="24"
                                           FontWeight="Bold" />
                                <TextBlock Text="Vui lòng chọn thông tin phòng để gửi yêu cầu đăng ký."
                                           Style="{StaticResource StudentDashboardSupportingTextStyle}"
                                           Margin="0,6,0,0" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding CloseRoomRegistrationPopupCommand}"
                                    Style="{StaticResource StudentDashboardHeaderIconButtonStyle}"
                                    Width="40"
                                    Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                                <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" />
                            </Button>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,0,0,0"
                                Height="1"
                                Background="{StaticResource StudentDashboardSurfaceContainerBrush}" />

                        <Grid Grid.Row="2" DataContext="{Binding RoomRegistrationModal}" Margin="32,24,32,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <controls:ErrorState Title="Không thể tải đăng ký phòng"
                                                 Message="{Binding ErrorMessage}"
                                                 Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                                 Margin="0,0,0,16" />

                            <TextBlock Grid.Row="1"
                                       Text="{Binding AvailabilityStatusMessage}"
                                       Visibility="{Binding AvailabilityStatusMessage, Converter={StaticResource StringToVisibility}}"
                                       Style="{StaticResource StudentDashboardPopupStatusTextStyle}"
                                       Margin="0,0,0,16"
                                       TextWrapping="Wrap" />

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Grid IsEnabled="{Binding IsRegistrationLocked, Converter={StaticResource InverseBool}}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Khu vực"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <ComboBox ItemsSource="{Binding BuildingOptions}"
                                                      SelectedItem="{Binding SelectedBuilding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      Height="58"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="0,8,0,0"
                                                      Padding="12,10" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="Tầng"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <ComboBox ItemsSource="{Binding FloorOptions}"
                                                      SelectedItem="{Binding SelectedFloor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      Height="58"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="0,8,0,0"
                                                      Padding="12,10" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,20,0,0">
                                            <TextBlock Text="Loại phòng"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <ComboBox ItemsSource="{Binding RoomTypeOptions}"
                                                      SelectedItem="{Binding SelectedRoomType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      Height="58"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="0,8,0,0"
                                                      Padding="12,10" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,20,0,0">
                                            <TextBlock Text="Số phòng"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <ComboBox ItemsSource="{Binding AvailableRooms}"
                                                      SelectedItem="{Binding SelectedRoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      DisplayMemberPath="RoomNumber"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      Height="58"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="0,8,0,0"
                                                      Padding="12,10" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,20,0,0" MaxWidth="308" HorizontalAlignment="Left">
                                            <TextBlock Text="Thời hạn hợp đồng"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <ComboBox ItemsSource="{Binding ContractTermOptions}"
                                                      SelectedItem="{Binding ContractTermMonths, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                      Height="58"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Margin="0,8,0,0"
                                                      Padding="12,10" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,20,0,0">
                                            <TextBlock Text="Ghi chú"
                                                       Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}" />
                                            <TextBox Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,8,0,0"
                                                     Padding="12,10"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     Height="92"
                                                     VerticalScrollBarVisibility="Auto" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,16,0,0"
                                            Padding="16,14"
                                            Background="{StaticResource StudentDashboardSurfaceLowBrush}"
                                            BorderBrush="{StaticResource StudentDashboardSurfaceHighBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <CheckBox IsChecked="{Binding AcceptsDormRules, Mode=TwoWay}">
                                            <TextBlock Text="Tôi đồng ý với nội quy KTX và cam kết thanh toán đúng hạn."
                                                       Style="{StaticResource StudentDashboardCardMetaTextStyle}"
                                                       Foreground="{StaticResource StudentDashboardTextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </CheckBox>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="3"
                                BorderBrush="{StaticResource StudentDashboardSurfaceContainerBrush}"
                                BorderThickness="0,1,0,0"
                                Background="{StaticResource StudentDashboardCanvasBrush}">
                            <Grid Margin="32,20,32,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding RoomRegistrationModal.StatusMessage}"
                                           Visibility="{Binding RoomRegistrationModal.StatusMessage, Converter={StaticResource StringToVisibility}}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource StudentDashboardPopupStatusTextStyle}"
                                           TextWrapping="Wrap" />

                                <Button Grid.Column="1"
                                        Command="{Binding CloseRoomRegistrationPopupCommand}"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Padding="18,12"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="Hủy"
                                               Style="{StaticResource StudentDashboardStatusLabelTextStyle}"
                                               Foreground="{StaticResource StudentDashboardTextSecondaryBrush}" />
                                </Button>

                                <Button Grid.Column="2"
                                        Command="{Binding RoomRegistrationModal.SubmitCommand}"
                                        Style="{StaticResource StudentDashboardPrimaryCtaButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Gửi yêu cầu đăng ký"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center" />
                                        <iconPacks:PackIconMaterial Kind="Send"
                                                                    Width="14"
                                                                    Height="14"
                                                                    VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <controls:LoadingOverlay Message="Loading student dashboard..."
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>

