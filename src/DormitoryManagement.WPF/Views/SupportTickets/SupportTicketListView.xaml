<UserControl x:Class="DormitoryManagement.WPF.Views.SupportTickets.SupportTicketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             Loaded="OnLoaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <controls:PageHeader Title="Support Tickets" Subtitle="Track maintenance, billing, account, and safety requests.">
                    <controls:PageHeader.Actions>
                        <controls:StatusBadge Status="New" Text="Queue" />
                    </controls:PageHeader.Actions>
                </controls:PageHeader>

                <controls:ErrorState Title="Ticket action failed"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,14" />

                <Border Background="{StaticResource SuccessLightBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasSuccessMessage, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <controls:SearchFilterBar>
                            <controls:SearchFilterBar.FilterContent>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" AutomationProperties.Name="Ticket status filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding CategoryFilters}" SelectedItem="{Binding SelectedCategoryFilter}" AutomationProperties.Name="Ticket category filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding PriorityFilters}" SelectedItem="{Binding SelectedPriorityFilter}" AutomationProperties.Name="Ticket priority filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                        <Button Content="Apply" Command="{Binding ApplyFiltersCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                        <Button Content="Clear" Command="{Binding ClearFiltersCommand}" />
                                    </StackPanel>
                                </Grid>
                            </controls:SearchFilterBar.FilterContent>
                        </controls:SearchFilterBar>

                        <Border Style="{StaticResource SectionCardStyle}" MinHeight="440">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Ticket queue" Style="{StaticResource SectionTitle}" />
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding Tickets}"
                                          SelectedItem="{Binding SelectedTicket}"
                                          Visibility="{Binding HasTickets, Converter={StaticResource BoolToVisibility}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*" />
                                        <DataGridTextColumn Header="Student" Binding="{Binding StudentCode}" Width="*" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
                                        <DataGridTemplateColumn Header="Priority" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><controls:StatusBadge Status="{Binding Priority}" /></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate><controls:StatusBadge Status="{Binding Status}" /></DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=g}" Width="1.2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <controls:EmptyState Grid.Row="1"
                                                     Title="No support tickets"
                                                     Message="Tickets you create or receive will appear here with status and priority."
                                                     Icon="!"
                                                     Visibility="{Binding IsTicketsEmpty, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" MinHeight="540">
                        <StackPanel>
                            <StackPanel Visibility="{Binding IsStaffUser, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Update selected ticket" Style="{StaticResource SectionTitle}" />
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusToApply}" AutomationProperties.Name="Ticket status update" />
                                <TextBox Text="{Binding StatusNote, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Ticket status note"
                                         Margin="0,10,0,0"
                                         TextWrapping="Wrap" />
                                <Button Content="Update Status"
                                        Command="{Binding UpdateStatusCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,12,0,22" />
                            </StackPanel>

                            <TextBlock Text="Create ticket" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Ticket title" />
                            <TextBlock Text="{Binding TitleError}" Style="{StaticResource FieldErrorStyle}" Visibility="{Binding HasTitleError, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Ticket description" AcceptsReturn="True" Height="100" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                            <TextBlock Text="{Binding DescriptionError}" Style="{StaticResource FieldErrorStyle}" Visibility="{Binding HasDescriptionError, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" AutomationProperties.Name="Ticket category" />
                            <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                            <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}" AutomationProperties.Name="Ticket priority" />
                            <Button Content="Create Support Ticket" Command="{Binding CreateTicketCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <controls:LoadingOverlay Message="Saving ticket..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
