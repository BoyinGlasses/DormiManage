<UserControl x:Class="DormitoryManagement.WPF.Views.SupportTickets.SupportTicketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             xmlns:converters="clr-namespace:DormitoryManagement.WPF.Converters"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextHintingMode="Fixed"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <converters:SupportTicketValueConverter x:Key="SupportTicketValueConverter" />
        <SolidColorBrush x:Key="SupportTicketsBadgeInfoBackgroundBrush" Color="#FEE2D7" />
        <SolidColorBrush x:Key="SupportTicketsBadgeInfoForegroundBrush" Color="#5F1900" />
        <SolidColorBrush x:Key="SupportTicketsBadgeInfoBorderBrush" Color="#FFD0BF" />
        <SolidColorBrush x:Key="SupportTicketsBadgeWarningBackgroundBrush" Color="#E1E0FF" />
        <SolidColorBrush x:Key="SupportTicketsBadgeWarningForegroundBrush" Color="#2F2EBE" />
        <SolidColorBrush x:Key="SupportTicketsBadgeWarningBorderBrush" Color="#C0C1FF" />
        <SolidColorBrush x:Key="SupportTicketsBadgeSuccessBackgroundBrush" Color="#6FFBBE" />
        <SolidColorBrush x:Key="SupportTicketsBadgeSuccessForegroundBrush" Color="#003A25" />
        <SolidColorBrush x:Key="SupportTicketsBadgeSuccessBorderBrush" Color="#4EDEA3" />
        <SolidColorBrush x:Key="SupportTicketsBadgeDangerBackgroundBrush" Color="#FFDAD6" />
        <SolidColorBrush x:Key="SupportTicketsBadgeDangerForegroundBrush" Color="#93000A" />
        <SolidColorBrush x:Key="SupportTicketsBadgeDangerBorderBrush" Color="#F3B8B2" />
        <Style x:Key="SupportTicketsBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="MinHeight" Value="{StaticResource SupportTicketsBadgeMinHeight}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SupportTicketsBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SupportTicketsBodyFontFamily}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SupportTicketsActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="{StaticResource SupportTicketsActionButtonSize}" />
            <Setter Property="Height" Value="{StaticResource SupportTicketsActionButtonSize}" />
            <Setter Property="Foreground" Value="{StaticResource SupportTicketsTextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="SupportTicketsDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SupportTicketsSurfaceContainerBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="FontFamily" Value="{StaticResource SupportTicketsBodyFontFamily}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource SupportTicketsTextPrimaryBrush}" />
        </Style>
        <Style x:Key="SupportTicketsDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SupportTicketsSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SupportTicketsSurfaceHighBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="{StaticResource SupportTicketsDataGridHeaderPadding}" />
            <Setter Property="Height" Value="{StaticResource SupportTicketsDataGridHeaderHeight}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontFamily" Value="{StaticResource SupportTicketsBodyFontFamily}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SupportTicketsTextSecondaryBrush}" />
        </Style>
        <Style x:Key="SupportTicketsDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="{StaticResource SupportTicketsDataGridCellPadding}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="SupportTicketsDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="{StaticResource SupportTicketsDataGridRowMinHeight}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
    </UserControl.Resources>
    <Grid Background="{StaticResource SupportTicketsCanvasBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid HorizontalAlignment="Center" MaxWidth="{StaticResource SupportTicketsPageMaxWidth}" Margin="{StaticResource SupportTicketsPageOuterMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="{StaticResource SupportTicketsTitleMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Yêu cầu hỗ trợ" Style="{StaticResource SupportTicketsPageTitleTextStyle}" />
                        <TextBlock Text="Quản lý và theo dõi các yêu cầu dịch vụ kỹ thuật của bạn." Style="{StaticResource SupportTicketsBodyTextStyle}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ToggleCreateFormCommand}" Style="{StaticResource SupportTicketsPrimaryButtonStyle}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Width="14" Height="14" Margin="{StaticResource SupportTicketsInlineIconMargin}" VerticalAlignment="Center" />
                            <TextBlock Text="Gửi yêu cầu mới" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <controls:ErrorState Grid.Row="1" Title="Ticket action failed" Message="{Binding ErrorMessage}" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" Margin="{StaticResource SupportTicketsFeedbackMargin}" />
                <Border Grid.Row="1" Background="#FFF3E8" BorderBrush="{StaticResource SupportTicketsPrimaryContainerBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="{StaticResource SupportTicketsFeedbackMargin}" Visibility="{Binding HasSuccessMessage, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SupportTicketsPrimaryBrush}" FontFamily="{StaticResource SupportTicketsBodyFontFamily}" FontSize="13" FontWeight="SemiBold" />
                </Border>

                <Grid Grid.Row="2" Margin="{StaticResource SupportTicketsSummaryMargin}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SupportTicketsCardStyle}" MinHeight="{StaticResource SupportTicketsSummaryCardMinHeight}" Padding="{StaticResource SupportTicketsSummaryCardPadding}" Background="{StaticResource SupportTicketsSurfaceBrush}">
                        <DockPanel LastChildFill="True">
                            <Border Width="{StaticResource SupportTicketsSummaryIconSize}" Height="{StaticResource SupportTicketsSummaryIconSize}" Background="{StaticResource SupportTicketsSurfaceContainerBrush}" CornerRadius="20" Margin="0,0,12,0" DockPanel.Dock="Left">
                                <iconPacks:PackIconMaterial Kind="ReceiptTextOutline" Width="18" Height="18" Foreground="{StaticResource SupportTicketsPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tổng số yêu cầu" Style="{StaticResource SupportTicketsSummaryLabelTextStyle}" />
                                <TextBlock Text="{Binding TotalTicketCountText}" Style="{StaticResource SupportTicketsSummaryValueTextStyle}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource SupportTicketsCardStyle}" MinHeight="{StaticResource SupportTicketsSummaryCardMinHeight}" Padding="{StaticResource SupportTicketsSummaryCardPadding}" Background="{StaticResource SupportTicketsSurfaceBrush}">
                        <DockPanel LastChildFill="True">
                            <Border Width="{StaticResource SupportTicketsSummaryIconSize}" Height="{StaticResource SupportTicketsSummaryIconSize}" Background="#FFFFDBD0" CornerRadius="20" Margin="0,0,12,0" DockPanel.Dock="Left">
                                <iconPacks:PackIconMaterial Kind="HammerWrench" Width="18" Height="18" Foreground="{StaticResource SupportTicketsPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Đang xử lý" Style="{StaticResource SupportTicketsSummaryLabelTextStyle}" />
                                <TextBlock Text="{Binding OpenTicketCountText}" Style="{StaticResource SupportTicketsSummaryValueTextStyle}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource SupportTicketsCardStyle}" MinHeight="{StaticResource SupportTicketsSummaryCardMinHeight}" Padding="{StaticResource SupportTicketsSummaryCardPadding}" Background="{StaticResource SupportTicketsSurfaceBrush}">
                        <DockPanel LastChildFill="True">
                            <Border Width="{StaticResource SupportTicketsSummaryIconSize}" Height="{StaticResource SupportTicketsSummaryIconSize}" Background="#FF6FFBBE" CornerRadius="20" Margin="0,0,12,0" DockPanel.Dock="Left">
                                <iconPacks:PackIconMaterial Kind="CheckCircle" Width="18" Height="18" Foreground="#FF003A25" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Đã hoàn thành" Style="{StaticResource SupportTicketsSummaryLabelTextStyle}" />
                                <TextBlock Text="{Binding ResolvedTicketCountText}" Style="{StaticResource SupportTicketsSummaryValueTextStyle}" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="3" Style="{StaticResource SupportTicketsCardStyle}" Padding="0">
                    <StackPanel>
                        <Border Background="{StaticResource SupportTicketsSurfaceBrush}" BorderBrush="{StaticResource SupportTicketsSurfaceContainerBrush}" BorderThickness="0,0,0,1" Padding="24,20">
                            <TextBlock Text="Danh sách yêu cầu gần đây" Style="{StaticResource SupportTicketsSectionTitleTextStyle}" />
                        </Border>

                        <StackPanel Margin="24,16,24,0" Visibility="Collapsed">
                            <Button Command="{Binding ToggleFiltersCommand}" Style="{StaticResource SupportTicketsSecondaryButtonStyle}" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FilterVariant" Width="14" Height="14" Margin="{StaticResource SupportTicketsInlineIconMargin}" VerticalAlignment="Center" />
                                    <TextBlock Text="Bộ lọc" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Border Background="{StaticResource SupportTicketsSurfaceLowBrush}" BorderBrush="{StaticResource SupportTicketsSurfaceContainerBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,12,0,0" Visibility="{Binding AreFiltersOpen, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" AutomationProperties.Name="Ticket status filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding CategoryFilters}" SelectedItem="{Binding SelectedCategoryFilter}" AutomationProperties.Name="Ticket category filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding PriorityFilters}" SelectedItem="{Binding SelectedPriorityFilter}" AutomationProperties.Name="Ticket priority filter" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                        <Button Content="Apply" Command="{Binding ApplyFiltersCommand}" Style="{StaticResource SupportTicketsPrimaryButtonStyle}" MinWidth="96" Margin="0,0,8,0" />
                                        <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource SupportTicketsSecondaryButtonStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}" Visibility="{Binding HasTickets, Converter={StaticResource BoolToVisibility}}" Style="{StaticResource SupportTicketsDataGridStyle}" ColumnHeaderStyle="{StaticResource SupportTicketsDataGridColumnHeaderStyle}" CellStyle="{StaticResource SupportTicketsDataGridCellStyle}" RowStyle="{StaticResource SupportTicketsDataGridRowStyle}" Margin="0,16,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã đơn" Width="1.25*" ElementStyle="{StaticResource SupportTicketsTableCellTextStyle}">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Id" Converter="{StaticResource SupportTicketValueConverter}" ConverterParameter="TicketReference" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Chủ đề" Binding="{Binding Title}" Width="2.25*" ElementStyle="{StaticResource SupportTicketsTableCellTextStyle}" />
                                <DataGridTextColumn Header="Loại vấn đề" Width="1.45*" ElementStyle="{StaticResource SupportTicketsTableCellTextStyle}">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Category" Converter="{StaticResource SupportTicketValueConverter}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Ngày gửi" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy}" Width="1.1*" ElementStyle="{StaticResource SupportTicketsTableCellTextStyle}" />
                                <DataGridTemplateColumn Header="Trạng thái" Width="1.35*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border x:Name="StatusBadgeBorder" Style="{StaticResource SupportTicketsBadgeBorderStyle}" HorizontalAlignment="Left" Background="{StaticResource SupportTicketsBadgeInfoBackgroundBrush}" BorderBrush="{StaticResource SupportTicketsBadgeInfoBorderBrush}">
                                                <TextBlock x:Name="StatusBadgeText" Text="{Binding Status, Converter={StaticResource SupportTicketValueConverter}}" Style="{StaticResource SupportTicketsBadgeTextStyle}" Foreground="{StaticResource SupportTicketsBadgeInfoForegroundBrush}" />
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                    <Setter TargetName="StatusBadgeBorder" Property="Background" Value="{StaticResource SupportTicketsBadgeWarningBackgroundBrush}" />
                                                    <Setter TargetName="StatusBadgeBorder" Property="BorderBrush" Value="{StaticResource SupportTicketsBadgeWarningBorderBrush}" />
                                                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SupportTicketsBadgeWarningForegroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Assigned">
                                                    <Setter TargetName="StatusBadgeBorder" Property="Background" Value="{StaticResource SupportTicketsBadgeWarningBackgroundBrush}" />
                                                    <Setter TargetName="StatusBadgeBorder" Property="BorderBrush" Value="{StaticResource SupportTicketsBadgeWarningBorderBrush}" />
                                                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SupportTicketsBadgeWarningForegroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Resolved">
                                                    <Setter TargetName="StatusBadgeBorder" Property="Background" Value="{StaticResource SupportTicketsBadgeSuccessBackgroundBrush}" />
                                                    <Setter TargetName="StatusBadgeBorder" Property="BorderBrush" Value="{StaticResource SupportTicketsBadgeSuccessBorderBrush}" />
                                                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SupportTicketsBadgeSuccessForegroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Closed">
                                                    <Setter TargetName="StatusBadgeBorder" Property="Background" Value="{StaticResource SupportTicketsBadgeSuccessBackgroundBrush}" />
                                                    <Setter TargetName="StatusBadgeBorder" Property="BorderBrush" Value="{StaticResource SupportTicketsBadgeSuccessBorderBrush}" />
                                                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SupportTicketsBadgeSuccessForegroundBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                    <Setter TargetName="StatusBadgeBorder" Property="Background" Value="{StaticResource SupportTicketsBadgeDangerBackgroundBrush}" />
                                                    <Setter TargetName="StatusBadgeBorder" Property="BorderBrush" Value="{StaticResource SupportTicketsBadgeDangerBorderBrush}" />
                                                    <Setter TargetName="StatusBadgeText" Property="Foreground" Value="{StaticResource SupportTicketsBadgeDangerForegroundBrush}" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Hành động" Width="0.95*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Command="{Binding DataContext.SelectTicketCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource SupportTicketsActionButtonStyle}" Margin="0,0,4,0" AutomationProperties.Name="Xem yêu cầu">
                                                    <iconPacks:PackIconMaterial Kind="EyeOutline" Width="{StaticResource SupportTicketsActionIconSize}" Height="{StaticResource SupportTicketsActionIconSize}" />
                                                </Button>
                                                <Button Command="{Binding DataContext.SecondaryTicketActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource SupportTicketsActionButtonStyle}" AutomationProperties.Name="Xóa yêu cầu">
                                                    <iconPacks:PackIconMaterial Kind="DeleteOutline" Width="{StaticResource SupportTicketsActionIconSize}" Height="{StaticResource SupportTicketsActionIconSize}" Foreground="#FFBA1A1A" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Background="{StaticResource SupportTicketsSurfaceBrush}" BorderBrush="{StaticResource SupportTicketsSurfaceContainerBrush}" BorderThickness="0,1,0,0" Padding="14,12" Visibility="{Binding HasTickets, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TicketFooterSummaryText}" Style="{StaticResource SupportTicketsBodyTextStyle}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="Trước" Style="{StaticResource SupportTicketsSecondaryButtonStyle}" IsEnabled="False" Margin="0,0,8,0" />
                                    <Button Content="Sau" Style="{StaticResource SupportTicketsSecondaryButtonStyle}" IsEnabled="False" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Margin="24,16,24,24" Background="Transparent" Visibility="{Binding IsTicketsEmpty, Converter={StaticResource BoolToVisibility}}">
                            <controls:EmptyState Title="No support tickets" Message="Tickets you create or receive will appear here with status and priority." Icon="!" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource SupportTicketsCardStyle}" Margin="0,24,0,0" HorizontalAlignment="Left" Width="{StaticResource SupportTicketsFormWidth}" Visibility="{Binding IsCreateFormOpen, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Gửi yêu cầu mới" Style="{StaticResource SupportTicketsSectionTitleTextStyle}" />
                        <TextBlock Text="Điền đầy đủ thông tin để bộ phận kỹ thuật tiếp nhận nhanh hơn." Style="{StaticResource SupportTicketsBodyTextStyle}" Margin="0,4,0,18" />
                        <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Ticket title" />
                        <TextBlock Text="{Binding TitleError}" Style="{StaticResource FieldErrorStyle}" Visibility="{Binding HasTitleError, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Ticket description" AcceptsReturn="True" Height="112" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <TextBlock Text="{Binding DescriptionError}" Style="{StaticResource FieldErrorStyle}" Visibility="{Binding HasDescriptionError, Converter={StaticResource BoolToVisibility}}" />
                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" AutomationProperties.Name="Ticket category" />
                        <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                        <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Priority}" AutomationProperties.Name="Ticket priority" />
                        <Button Content="Create Support Ticket" Command="{Binding CreateTicketCommand}" Style="{StaticResource SupportTicketsPrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,18,0,0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="5" Margin="0,24,0,0" Visibility="{Binding IsStaffUser, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Update selected ticket" Style="{StaticResource SupportTicketsSectionTitleTextStyle}" />
                    <Border Style="{StaticResource SupportTicketsCardStyle}" Margin="0,12,0,0" HorizontalAlignment="Left" Width="{StaticResource SupportTicketsFormWidth}">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusToApply}" AutomationProperties.Name="Ticket status update" />
                            <TextBox Text="{Binding StatusNote, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.Name="Ticket status note" Margin="0,10,0,0" TextWrapping="Wrap" Height="90" AcceptsReturn="True" />
                            <Button Content="Update Status" Command="{Binding UpdateStatusCommand}" Style="{StaticResource SupportTicketsPrimaryButtonStyle}" HorizontalAlignment="Left" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
        <controls:LoadingOverlay Message="Saving ticket..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>

