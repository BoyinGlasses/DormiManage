<UserControl x:Class="DormitoryManagement.WPF.Views.Billing.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             Loaded="OnLoaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <controls:PageHeader Title="Payments" Subtitle="Record and review payment attempts for student invoices." />

                <controls:ErrorState Title="Payment failed"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,14" />

                <Border Background="{StaticResource SuccessLightBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasSuccessMessage, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Visibility="{Binding IsStudent, Converter={StaticResource BoolToVisibility}}">
                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Invoice to pay" Style="{StaticResource SectionTitle}" />
                                <ComboBox ItemsSource="{Binding OutstandingInvoices}"
                                          SelectedItem="{Binding SelectedInvoice}"
                                          DisplayMemberPath="InvoiceNumber"
                                          AutomationProperties.Name="Outstanding invoice" />
                                <DataGrid ItemsSource="{Binding OutstandingInvoices}"
                                          SelectedItem="{Binding SelectedInvoice}"
                                          Visibility="{Binding HasOutstandingInvoices, Converter={StaticResource BoolToVisibility}}"
                                          Margin="0,12,0,0"
                                          MaxHeight="180">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="*" />
                                        <DataGridTextColumn Header="Kind" Binding="{Binding InvoiceKind}" Width="*" />
                                        <DataGridTextColumn Header="Period" Binding="{Binding BillingPeriod}" Width="*" />
                                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat=d}" Width="*" />
                                        <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingAmount, StringFormat=N0}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <controls:EmptyState Title="No outstanding invoices"
                                                     Message="Outstanding invoices will appear here when payment is due."
                                                     Icon="PV"
                                                     Visibility="{Binding IsOutstandingInvoicesEmpty, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="{Binding InvoiceNumber}" Style="{StaticResource HeadingText}" Margin="0,12,0,0" />
                                <TextBlock Text="Remaining" Style="{StaticResource LabelText}" Margin="0,12,0,4" />
                                <TextBlock Text="{Binding InvoiceRemainingText}" Style="{StaticResource TitleText}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="QR bank transfer" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0" />
                                    <controls:StatusBadge Status="{Binding QrStatus}" DockPanel.Dock="Right" />
                                </DockPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="160"
                                            Height="160"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            Visibility="{Binding HasQrImage, Converter={StaticResource BoolToVisibility}}">
                                        <Image Source="{Binding QrDataUrl, Converter={StaticResource QrDataUrlToImageSource}}"
                                               Stretch="Uniform"
                                               AutomationProperties.Name="Payment QR code" />
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Amount" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding QrAmountText}" Style="{StaticResource HeadingText}" Margin="0,2,0,10" />

                                        <TextBlock Text="Transfer content" Style="{StaticResource LabelText}" />
                                        <Border Background="{StaticResource SurfaceAltBrush}"
                                                BorderBrush="{StaticResource BorderLightBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10"
                                                Margin="0,4,0,10">
                                            <TextBlock Text="{Binding QrTransferContent}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Due date" Style="{StaticResource LabelText}" />
                                                <TextBlock Text="{Binding QrDueDateText}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Paid at" Style="{StaticResource LabelText}" />
                                                <TextBlock Text="{Binding QrPaidAtText}" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding QrStatusMessage}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,12,0,0"
                                           Visibility="{Binding HasQrStatusMessage, Converter={StaticResource BoolToVisibility}}" />
                                <controls:EmptyState Title="QR not ready"
                                                     Message="Payment instructions will appear after staff generate QR details."
                                                     Icon="QR"
                                                     Visibility="{Binding IsQrMissing, Converter={StaticResource BoolToVisibility}}" />
                                <Button Content="Refresh payment status"
                                        Command="{Binding RefreshQrStatusCommand}"
                                        IsEnabled="{Binding CanRefreshQrStatus}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,16,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Manual payment request" Style="{StaticResource SectionTitle}" />

                                <TextBlock Text="Amount" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                                <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" AutomationProperties.Name="Payment amount" />
                                <TextBlock Text="{Binding AmountError}"
                                           Style="{StaticResource FieldErrorStyle}"
                                           Visibility="{Binding HasAmountError, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="Payment method" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                                <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding Method}" AutomationProperties.Name="Payment method" />

                                <Button Content="Create pending payment" Command="{Binding CreatePaymentCommand}" IsEnabled="{Binding CanCreatePayment}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Request extension" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="Invoice" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding InvoiceNumber}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="Kind" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoiceKind}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="Room" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoiceRoomNumber}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <TextBlock Text="Period" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoice.BillingPeriod}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="0">
                                        <TextBlock Text="Total" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoice.TotalAmount, StringFormat={}{0:N0} VND}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="1">
                                        <TextBlock Text="Paid" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoice.PaidAmount, StringFormat={}{0:N0} VND}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="6" Grid.Column="0">
                                        <TextBlock Text="Current due" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding SelectedInvoice.DueDate, StringFormat=d}" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="6" Grid.Column="1">
                                        <TextBlock Text="Max due" Style="{StaticResource LabelText}" />
                                        <TextBlock Text="{Binding ExtensionMaxDueDate, StringFormat=d}"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding HasExtensionMaxDueDate, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Requested due date" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                                <DatePicker SelectedDate="{Binding ExtensionRequestedDueDate}" AutomationProperties.Name="Extension due date" />
                                <TextBlock Text="{Binding ExtensionDueDateError}"
                                           Style="{StaticResource FieldErrorStyle}"
                                           Visibility="{Binding HasExtensionDueDateError, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="Reason" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                                <TextBox Text="{Binding ExtensionReason, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="72"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         AutomationProperties.Name="Extension reason" />
                                <Button Content="Request extension"
                                        Command="{Binding RequestExtensionCommand}"
                                        IsEnabled="{Binding CanRequestExtension}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" MinHeight="480" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock Text="Pending payments" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left" Margin="0" />
                                <controls:StatusBadge Status="Info" Text="Manual review ready" DockPanel.Dock="Right" />
                            </DockPanel>
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Payments}"
                                      SelectedItem="{Binding SelectedPendingPayment}"
                                      Visibility="{Binding HasPendingPayments, Converter={StaticResource BoolToVisibility}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Code" Binding="{Binding PaymentCode}" Width="*" />
                                    <DataGridTextColumn Header="Student" Binding="{Binding StudentCode}" Width="*" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding StudentName}" Width="1.5*" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N0}" Width="*" />
                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*" />
                                    <DataGridTemplateColumn Header="Status" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <controls:StatusBadge Status="{Binding Status}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Transaction Ref" Binding="{Binding TransactionRef}" Width="1.5*" />
                                    <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat=g}" Width="1.2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0" Visibility="{Binding HasPendingPayments, Converter={StaticResource BoolToVisibility}}">
                                <TextBox Width="240"
                                         Text="{Binding ConfirmationReference, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Confirmation reference"
                                         Margin="0,0,8,0" />
                                <Button Content="Confirm selected payment"
                                        Command="{Binding ConfirmPaymentCommand}"
                                        IsEnabled="{Binding CanConfirmPayment}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                            <controls:EmptyState Grid.Row="1"
                                                 Title="No payment yet"
                                                 Message="Created payments will appear here with method, status, and transaction reference."
                                                 Icon="●"
                                                 Visibility="{Binding IsPendingPaymentsEmpty, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <controls:LoadingOverlay Message="Confirming payment..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
