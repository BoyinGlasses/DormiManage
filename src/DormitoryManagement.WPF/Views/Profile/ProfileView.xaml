<UserControl x:Class="DormitoryManagement.WPF.Views.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="{StaticResource BackgroundBrush}">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="88"
                            Height="88"
                            CornerRadius="44"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock Text="{Binding AvatarInitial}"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding RoleName}"
                                   Margin="0,6,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Email}"
                                   Margin="0,4,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Thông tin tài khoản"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Tên đăng nhập"
                                   Margin="0,20,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Username}"
                                   FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Email"
                                   Margin="0,18,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding Email}"
                                   FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Định danh"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Vai trò"
                                   Margin="0,20,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding RoleName}"
                                   FontSize="16"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Mã định danh"
                                   Margin="0,18,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{Binding IdentityLabel}"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>

