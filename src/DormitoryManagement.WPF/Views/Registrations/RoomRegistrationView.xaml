<UserControl x:Class="DormitoryManagement.WPF.Views.Registrations.RoomRegistrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             Loaded="OnLoaded">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">
                <controls:PageHeader Title="Room Registration" Subtitle="Choose an available room and submit a registration request." />

                <controls:ErrorState Title="Registration failed"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,14" />

                <Border Background="{StaticResource SuccessLightBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding StatusMessage, Converter={StaticResource NotNullToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" />
                </Border>

                <Border Background="{StaticResource InfoLightBrush}"
                        BorderBrush="{StaticResource InfoBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="{Binding RegistrationLockMessage, Converter={StaticResource NotNullToVisibility}}">
                    <TextBlock Text="{Binding RegistrationLockMessage}" Foreground="{StaticResource InfoBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <controls:SearchFilterBar>
                            <controls:SearchFilterBar.FilterContent>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Building" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding BuildingOptions}" SelectedItem="{Binding SelectedBuilding}" AutomationProperties.Name="Building filter" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Floor" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding FloorOptions}" SelectedItem="{Binding SelectedFloor}" AutomationProperties.Name="Floor filter" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Gender" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding SelectedGender}" AutomationProperties.Name="Gender filter" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="6">
                                        <TextBlock Text="Price" Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding PriceSortOptions}" SelectedItem="{Binding SelectedPriceSort}" AutomationProperties.Name="Price sort" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                        <Button Content="Apply" Command="{Binding ApplyFiltersCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                        <Button Content="Clear" Command="{Binding ClearFiltersCommand}" />
                                    </StackPanel>
                                </Grid>
                            </controls:SearchFilterBar.FilterContent>
                        </controls:SearchFilterBar>

                        <Border Style="{StaticResource SectionCardStyle}" MinHeight="420">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Available rooms" Style="{StaticResource SectionTitle}" />
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding AvailableRooms}"
                                          SelectedItem="{Binding SelectedRoom}"
                                          Visibility="{Binding HasAvailableRooms, Converter={StaticResource BoolToVisibility}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Building" Binding="{Binding BuildingName}" Width="1.2*" />
                                        <DataGridTextColumn Header="Floor" Binding="{Binding FloorNumber}" Width="0.7*" />
                                        <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="*" />
                                        <DataGridTextColumn Header="Available" Binding="{Binding AvailableSlots}" Width="*" />
                                        <DataGridTextColumn Header="Held" Binding="{Binding HeldSlots}" Width="*" />
                                        <DataGridTextColumn Header="Gender" Binding="{Binding GenderType}" Width="*" />
                                        <DataGridTextColumn Header="Price" Binding="{Binding MonthlyPrice, StringFormat=N0}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <controls:EmptyState Grid.Row="1"
                                                     Title="No available rooms"
                                                     Message="Available rooms will appear here when capacity and gender rules match."
                                                     Icon="RM"
                                                     Visibility="{Binding IsAvailableRoomsEmpty, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Submit request" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Selected room" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding SelectedRoom.RoomNumber}" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Contract term" Style="{StaticResource FieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding ContractTermOptions}"
                                          SelectedItem="{Binding ContractTermMonths}"
                                          IsEnabled="{Binding IsRegistrationLocked, Converter={StaticResource InverseBool}}"
                                          AutomationProperties.Name="Contract term" />
                                <CheckBox Content="Include internet service"
                                          IsChecked="{Binding IncludesInternet}"
                                          IsEnabled="{Binding IsRegistrationLocked, Converter={StaticResource InverseBool}}"
                                          Margin="0,12,0,12"
                                          AutomationProperties.Name="Include internet" />
                                <TextBlock Text="Note" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="78"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         IsEnabled="{Binding IsRegistrationLocked, Converter={StaticResource InverseBool}}"
                                         AutomationProperties.Name="Registration note" />
                                <Button Content="Submit registration"
                                        Command="{Binding SubmitCommand}"
                                        IsEnabled="{Binding CanSubmitRegistration}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}" MinHeight="260">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="My registrations" Style="{StaticResource SectionTitle}" />
                                <DataGrid Grid.Row="1" ItemsSource="{Binding RecentRegistrations}" Visibility="{Binding HasRecentRegistrations, Converter={StaticResource BoolToVisibility}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Room" Binding="{Binding RoomNumber}" Width="*" />
                                        <DataGridTextColumn Header="Term" Binding="{Binding ContractTermMonths}" Width="0.7*" />
                                        <DataGridCheckBoxColumn Header="Internet" Binding="{Binding IncludesInternet}" Width="0.8*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Requested" Binding="{Binding RequestedAt, StringFormat=d}" Width="*" />
                                        <DataGridTemplateColumn Header="Status" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <controls:StatusBadge Status="{Binding Status}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <controls:EmptyState Grid.Row="1"
                                                     Title="No registrations yet"
                                                     Message="Submitted room requests will appear here."
                                                     Icon="RG"
                                                     Visibility="{Binding IsRecentRegistrationsEmpty, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <controls:LoadingOverlay Message="Loading registration data..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
