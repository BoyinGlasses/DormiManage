<UserControl x:Class="DormitoryManagement.WPF.Views.Auth.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             TextElement.Foreground="{StaticResource TextPrimaryBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <LinearGradientBrush x:Key="RegisterOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#99145A32" Offset="0" />
                <GradientStop Color="#6622C55E" Offset="0.7" />
                <GradientStop Color="#33145A32" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="330"
                        HorizontalAlignment="Center"
                        Margin="0,42,0,42">
                <TextBlock Text="Create Student Account"
                           FontSize="25"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,6" />
                <TextBlock Text="Use your student details to create a sign-in account."
                           Style="{StaticResource CaptionText}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20" />

                <controls:ErrorState Title="Registration failed"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,12" />

                <Border Background="{StaticResource SuccessLightBrush}"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Visibility="{Binding HasSuccessMessage, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,0,12">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" TextWrapping="Wrap" />
                </Border>

                <TextBlock Style="{StaticResource FieldLabelStyle}">
                    <Run Text="Full name" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                         AutomationProperties.Name="Full name" />

                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6">
                    <Run Text="Email" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                         AutomationProperties.Name="Email" />

                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6">
                    <Run Text="Username" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                         AutomationProperties.Name="Username" />

                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6">
                    <Run Text="Student code" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <TextBox Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                         AutomationProperties.Name="Student code" />

                <TextBlock Text="Phone number" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6" />
                <TextBox Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                         AutomationProperties.Name="Phone number" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Gender" Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding GenderOptions}"
                                  SelectedItem="{Binding SelectedGender}"
                                  IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                                  AutomationProperties.Name="Gender" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date of birth" Style="{StaticResource FieldLabelStyle}" />
                        <ui:CalendarDatePicker Date="{Binding DateOfBirth, Mode=TwoWay}"
                                               Content="{Binding DateOfBirth, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue=Select date}"
                                               MinHeight="38"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Left"
                                               IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                                               AutomationProperties.Name="Date of birth" />
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6">
                    <Run Text="Password" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="PasswordBox_OnPasswordChanged"
                             IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                             AutomationProperties.Name="Password" />

                <TextBlock Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,6">
                    <Run Text="Confirm password" />
                    <Run Text=" *" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" />
                </TextBlock>
                <PasswordBox x:Name="ConfirmPasswordInput"
                             PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"
                             IsEnabled="{Binding IsFormLocked, Converter={StaticResource InverseBool}}"
                             AutomationProperties.Name="Confirm password" />

                <Button Content="Send verification code"
                        Command="{Binding RegisterCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                        Visibility="{Binding IsOtpStep, Converter={StaticResource InverseBoolToVisibility}}"
                        Margin="0,18,0,0" />

                <Border Background="#F0FDF4"
                        BorderBrush="{StaticResource SuccessBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,18,0,0"
                        Visibility="{Binding IsOtpStep, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Email verification"
                                   FontWeight="SemiBold"
                                   Foreground="#145A32" />
                        <TextBlock Text="{Binding OtpMessage}"
                                   Style="{StaticResource CaptionText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasOtpMessage, Converter={StaticResource BoolToVisibility}}"
                                   Margin="0,6,0,10" />
                        <TextBlock Text="Verification code" Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Text="{Binding OtpCode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="6"
                                 AutomationProperties.Name="Verification code" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Verify"
                                    Command="{Binding VerifyOtpCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsDefault="True"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
                            <Button Grid.Column="2"
                                    Content="Resend"
                                    Command="{Binding ResendOtpCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Button Content="Back to login"
                        Command="{Binding BackToLoginCommand}"
                        Style="{StaticResource TextButtonStyle}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="1" ClipToBounds="True">
            <Image Source="/Assets/Images/KTXB.png"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
            <Rectangle Fill="{StaticResource RegisterOverlayBrush}" />
            <StackPanel Margin="46"
                        VerticalAlignment="Bottom"
                        MaxWidth="560">
                <TextBlock Text="Dormitory Management"
                           Foreground="White"
                           FontSize="38"
                           FontWeight="Bold"
                           LineHeight="44"
                           TextWrapping="Wrap" />
                <TextBlock Text="Create a student account, then sign in with your email, username, or student code."
                           Foreground="#E6F7FA"
                           FontSize="15"
                           LineHeight="23"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0" />
            </StackPanel>
        </Grid>

        <controls:LoadingOverlay Grid.ColumnSpan="2"
                                 Message="Processing registration..."
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>
