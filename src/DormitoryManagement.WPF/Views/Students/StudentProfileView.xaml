<UserControl x:Class="DormitoryManagement.WPF.Views.Students.StudentProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:DormitoryManagement.WPF.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Loaded="OnLoaded">
    <Grid Background="{StaticResource ProfilePageCanvasBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,32"
                        HorizontalAlignment="Center"
                        MaxWidth="1360">
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="{Binding PageTitle}"
                               Style="{StaticResource ProfilePageTitleTextStyle}" />
                    <TextBlock Text="{Binding PageSubtitle}"
                               Style="{StaticResource ProfilePageBodyTextStyle}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <controls:ErrorState Title="Không thể tải hồ sơ cá nhân"
                                     Message="{Binding ErrorMessage}"
                                     Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                                     Margin="0,0,0,16" />

                <Border Background="{StaticResource ProfilePagePrimaryTintBrush}"
                        BorderBrush="{StaticResource ProfilePagePrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,12"
                        Margin="0,0,0,16"
                        Visibility="{Binding HasActionMessage, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ActionMessage}"
                               Foreground="{StaticResource ProfilePagePrimaryBrush}"
                               FontFamily="{StaticResource ProfilePageBodyFontFamily}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </Border>

                <WrapPanel ItemHeight="Auto"
                           Orientation="Horizontal">
                    <StackPanel Width="320"
                                MaxWidth="360"
                                Margin="0,0,24,24">
                        <Border Style="{StaticResource ProfilePageCardBorderStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Grid Margin="0,0,0,20">
                                    <Ellipse Width="128"
                                             Height="128"
                                             Stroke="{StaticResource ProfilePageSurfaceBrush}"
                                             StrokeThickness="4">
                                        <Ellipse.Fill>
                                            <ImageBrush ImageSource="{Binding AvatarImageSource}"
                                                        Stretch="UniformToFill" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <Button Command="{Binding EditProfileCommand}"
                                            Width="40"
                                            Height="40"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Style="{StaticResource ProfilePageFloatingIconButtonStyle}">
                                        <iconPacks:PackIconMaterial Kind="SquareEditOutline"
                                                                    Width="18"
                                                                    Height="18" />
                                    </Button>
                                </Grid>

                                <TextBlock Text="{Binding FullName}"
                                           Style="{StaticResource ProfilePageHeadlineTextStyle}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ProfileStatusMessage}"
                                           Style="{StaticResource ProfilePageMutedBodyTextStyle}"
                                           TextAlignment="Center"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />

                                <Border Background="{StaticResource ProfilePageSurfaceContainerBrush}"
                                        CornerRadius="999"
                                        Padding="10,4"
                                        Margin="0,14,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CardAccountDetailsOutline"
                                                                    Width="14"
                                                                    Height="14"
                                                                    Margin="0,0,6,0"
                                                                    VerticalAlignment="Center"
                                                                    Foreground="{StaticResource ProfilePageTextSecondaryBrush}" />
                                        <TextBlock Text="{Binding StudentCodeBadgeText}"
                                                   Style="{StaticResource ProfilePageBadgeTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ProfilePageCardBorderStyle}"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding DormitorySectionTitle}"
                                           Style="{StaticResource ProfilePageSectionTitleTextStyle}" />

                                <Border Style="{StaticResource ProfilePageSummaryTileStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                CornerRadius="20"
                                                Background="{StaticResource ProfilePagePrimaryTintBrush}">
                                            <iconPacks:PackIconMaterial Kind="Domain"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Foreground="{StaticResource ProfilePagePrimaryBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{Binding BuildingLabel}"
                                                       Style="{StaticResource ProfilePageTileLabelTextStyle}" />
                                            <TextBlock Text="{Binding BuildingName}"
                                                       Style="{StaticResource ProfilePageTileValueTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource ProfilePageSummaryTileStyle}"
                                        Margin="0,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                CornerRadius="20"
                                                Background="{StaticResource ProfilePageSecondaryTintBrush}">
                                            <iconPacks:PackIconMaterial Kind="Door"
                                                                        Width="18"
                                                                        Height="18"
                                                                        Foreground="{StaticResource ProfilePageSecondaryBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{Binding RoomLabelTitle}"
                                                       Style="{StaticResource ProfilePageTileLabelTextStyle}" />
                                            <TextBlock Text="{Binding RoomLabel}"
                                                       Style="{StaticResource ProfilePageTileValueTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Background="{StaticResource ProfilePageSurfaceLowBrush}"
                                        BorderBrush="{StaticResource ProfilePageSurfaceHighBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AssignmentStatus}"
                                                   Style="{StaticResource ProfilePageStatusTextStyle}" />
                                        <TextBlock Text="{Binding DormitorySupportMessage}"
                                                   Style="{StaticResource ProfilePageMutedBodyTextStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Width="760"
                                MaxWidth="980"
                                Margin="0,0,0,24">
                        <Border Style="{StaticResource ProfilePageCardBorderStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding PersonalInformationTitle}"
                                               Style="{StaticResource ProfilePageSectionTitleTextStyle}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Command="{Binding EditProfileCommand}"
                                            Style="{StaticResource ProfilePageGhostButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Kind="SquareEditOutline"
                                                                        Width="16"
                                                                        Height="16"
                                                                        Margin="0,0,6,0"
                                                                        VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding EditProfileLabel}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,24,18">
                                        <TextBlock Text="Họ và tên"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding FullName}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="Email"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding Email}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,18">
                                        <TextBlock Text="Số điện thoại"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding PhoneNumber}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,18">
                                        <TextBlock Text="Ngày sinh"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding DateOfBirth}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Giới tính"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding Gender}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Mã số sinh viên"
                                                   Style="{StaticResource ProfilePageFieldLabelTextStyle}" />
                                        <TextBlock Text="{Binding StudentCode}"
                                                   Style="{StaticResource ProfilePageFieldValueTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ProfilePageCardBorderStyle}"
                                Margin="0,16,0,0">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="{Binding AccountSettingsTitle}"
                                               Style="{StaticResource ProfilePageSectionTitleTextStyle}" />
                                    <TextBlock Text="{Binding AccountSettingsSubtitle}"
                                               Style="{StaticResource ProfilePageMutedBodyTextStyle}"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding AccountSettings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.OpenSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource ProfilePageSettingsButtonStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="40"
                                                            Height="40"
                                                            CornerRadius="20"
                                                            Background="{StaticResource ProfilePageSurfaceContainerBrush}">
                                                        <ContentControl HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="Content">
                                                                        <Setter.Value>
                                                                            <iconPacks:PackIconMaterial Kind="ChevronRight" Width="18" Height="18" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IconKey}" Value="lock">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <iconPacks:PackIconMaterial Kind="LockOutline" Width="18" Height="18" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IconKey}" Value="language">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <iconPacks:PackIconMaterial Kind="Translate" Width="18" Height="18" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="14,0,0,0">
                                                        <TextBlock Text="{Binding Label}"
                                                                   Style="{StaticResource ProfilePageSettingLabelTextStyle}" />
                                                        <TextBlock Text="{Binding SupportingText}"
                                                                   Style="{StaticResource ProfilePageMutedBodyTextStyle}"
                                                                   Margin="0,4,0,0"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding TrailingValue}"
                                                                   Visibility="{Binding HasTrailingValue, Converter={StaticResource BoolToVisibility}}"
                                                                   Style="{StaticResource ProfilePageTrailingValueTextStyle}"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center" />
                                                        <iconPacks:PackIconMaterial Kind="ChevronRight"
                                                                                    Width="18"
                                                                                    Height="18"
                                                                                    Foreground="{StaticResource ProfilePageTextSecondaryBrush}"
                                                                                    VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <controls:LoadingOverlay Message="Đang tải hồ sơ cá nhân..."
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</UserControl>

