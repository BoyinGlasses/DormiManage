    <SolidColorBrush x:Key="StudentDashboardTextSecondaryBrush" Color="{StaticResource StudentDashboardColorTextSecondary}" />
    <SolidColorBrush x:Key="StudentDashboardPrimaryBrush" Color="{StaticResource StudentDashboardColorPrimary}" />
    <SolidColorBrush x:Key="StudentDashboardPrimaryContainerBrush" Color="{StaticResource StudentDashboardColorPrimaryContainer}" />
    <SolidColorBrush x:Key="StudentDashboardSecondaryBrush" Color="{StaticResource StudentDashboardColorSecondary}" />
