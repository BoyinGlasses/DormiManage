    <SolidColorBrush x:Key="StudentDashboardTertiaryContainerBrush" Color="{StaticResource StudentDashboardColorTertiaryContainer}" />
    <SolidColorBrush x:Key="StudentDashboardOutlineBrush" Color="{StaticResource StudentDashboardColorOutline}" />
    <SolidColorBrush x:Key="StudentDashboardOutlineVariantBrush" Color="{StaticResource StudentDashboardColorOutlineVariant}" />
    <SolidColorBrush x:Key="StudentDashboardErrorBrush" Color="{StaticResource StudentDashboardColorError}" />
