    <SolidColorBrush x:Key="StudentDashboardSecondaryContainerTintBrush" Color="#1A6063EE" />
    <SolidColorBrush x:Key="StudentDashboardTertiaryContainerTintBrush" Color="#1A00AF79" />
    <SolidColorBrush x:Key="StudentDashboardPrimaryTintBrush" Color="#1AAB3500" />
