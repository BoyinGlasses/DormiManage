    <system:Double x:Key="StudentDashboardGridGap">16</system:Double>
    <system:Double x:Key="StudentDashboardTileGap">12</system:Double>
    <system:Double x:Key="StudentDashboardCardPadding">20</system:Double>
    <system:Double x:Key="StudentDashboardIconCircleSize">44</system:Double>
    <system:Double x:Key="StudentDashboardCardValueLarge">28</system:Double>
    <system:Double x:Key="StudentDashboardCardValueMedium">20</system:Double>
    <system:Double x:Key="StudentDashboardBodyLargeSize">14</system:Double>
    <system:Double x:Key="StudentDashboardBodySmallSize">14</system:Double>
    <system:Double x:Key="StudentDashboardSummaryCardWidth">270</system:Double>
    <system:Double x:Key="StudentDashboardSummaryCardMinHeight">188</system:Double>
    <system:Double x:Key="StudentDashboardQuickActionTileWidth">248</system:Double>
    <system:Double x:Key="StudentDashboardCardBorderThickness">1</system:Double>
    <system:Double x:Key="StudentDashboardCardShadowBlur">12</system:Double>
    <system:Double x:Key="StudentDashboardCardShadowDepth">2</system:Double>
    <system:Double x:Key="StudentDashboardCardShadowOpacity">0.03</system:Double>
    <system:Double x:Key="StudentDashboardHeaderIconButtonSize">40</system:Double>
    <system:Double x:Key="StudentDashboardCardIconSize">18</system:Double>
    <system:Double x:Key="StudentDashboardQuickActionIconSize">22</system:Double>
    <system:Double x:Key="StudentDashboardBrandIconContainerSize">30</system:Double>
    <system:Double x:Key="StudentDashboardAvatarSize">36</system:Double>
    <system:Double x:Key="StudentDashboardNotificationDotSize">8</system:Double>
    <system:Double x:Key="StudentDashboardPopupWidth">672</system:Double>
    <system:Double x:Key="StudentDashboardPopupMaxHeight">760</system:Double>
    <system:Double x:Key="StudentDashboardPopupShadowBlur">50</system:Double>
    <system:Double x:Key="StudentDashboardPopupShadowDepth">8</system:Double>
    <system:Double x:Key="StudentDashboardPopupShadowOpacity">0.12</system:Double>

    <CornerRadius x:Key="StudentDashboardCardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="StudentDashboardControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="StudentDashboardPillCornerRadius">999</CornerRadius>
    <CornerRadius x:Key="StudentDashboardStatusBadgeCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="StudentDashboardPopupCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="StudentDashboardAvatarCornerRadius">18</CornerRadius>
    <CornerRadius x:Key="StudentDashboardBrandIconCornerRadius">15</CornerRadius>
    <CornerRadius x:Key="StudentDashboardIconButtonCornerRadius">20</CornerRadius>

    <Thickness x:Key="StudentDashboardCardPaddingThickness">20</Thickness>
    <Thickness x:Key="StudentDashboardCardBorderThicknessValue">1</Thickness>
    <Thickness x:Key="StudentDashboardQuickActionTilePadding">16</Thickness>
    <Thickness x:Key="StudentDashboardRefreshButtonPadding">14,7</Thickness>
    <Thickness x:Key="StudentDashboardStatusPillPadding">12,4</Thickness>
    <Thickness x:Key="StudentDashboardHeaderOuterPadding">32,12,32,12</Thickness>
    <Thickness x:Key="StudentDashboardHeaderBrandMargin">0,0,24,8</Thickness>
    <Thickness x:Key="StudentDashboardHeaderNavMargin">32,0,0,0</Thickness>
    <Thickness x:Key="StudentDashboardHeaderActionsMargin">0,0,0,0</Thickness>
    <Thickness x:Key="StudentDashboardQuickActionTileMargin">0,0,16,16</Thickness>
    <Thickness x:Key="StudentDashboardSummaryCardMargin">0,0,16,16</Thickness>
    <Thickness x:Key="StudentDashboardPopupPadding">0</Thickness>
    <Thickness x:Key="StudentDashboardPopupMargin">16</Thickness>
    <Thickness x:Key="StudentDashboardSectionTitleMargin">0,0,0,16</Thickness>
    <Thickness x:Key="StudentDashboardRefreshMargin">16,0,0,0</Thickness>
    <Thickness x:Key="StudentDashboardRefreshIconMargin">0,0,8,0</Thickness>
    <Thickness x:Key="StudentDashboardInlineArrowMargin">6,0,0,0</Thickness>
    <Thickness x:Key="StudentDashboardQuickActionLabelMargin">0,12,0,0</Thickness>
    <Thickness x:Key="StudentDashboardNotificationDotMargin">0,9,9,0</Thickness>

    <DropShadowEffect x:Key="StudentDashboardCardShadowEffect"
                      BlurRadius="{StaticResource StudentDashboardCardShadowBlur}"
                      ShadowDepth="{StaticResource StudentDashboardCardShadowDepth}"
                      Opacity="{StaticResource StudentDashboardCardShadowOpacity}"
                      Color="#000000" />

    <DropShadowEffect x:Key="StudentDashboardPopupShadowEffect"
                      BlurRadius="{StaticResource StudentDashboardPopupShadowBlur}"
                      ShadowDepth="{StaticResource StudentDashboardPopupShadowDepth}"
                      Opacity="{StaticResource StudentDashboardPopupShadowOpacity}"
                      Color="#000000" />

    <SolidColorBrush x:Key="StudentDashboardBadgeDangerBackgroundBrush" Color="#FFFBEDEC" />
    <SolidColorBrush x:Key="StudentDashboardBadgeDangerForegroundBrush" Color="#B3261E" />
    <SolidColorBrush x:Key="StudentDashboardBadgeDangerBorderBrush" Color="#F2B8B5" />
    <SolidColorBrush x:Key="StudentDashboardBadgeSuccessBackgroundBrush" Color="#FFF0FBF7" />
    <SolidColorBrush x:Key="StudentDashboardBadgeSuccessForegroundBrush" Color="#0B8C67" />
    <SolidColorBrush x:Key="StudentDashboardBadgeSuccessBorderBrush" Color="#BFE7D9" />
    <SolidColorBrush x:Key="StudentDashboardBadgeNeutralBackgroundBrush" Color="#FFF6F8FF" />
    <SolidColorBrush x:Key="StudentDashboardBadgeNeutralForegroundBrush" Color="#233143" />
    <SolidColorBrush x:Key="StudentDashboardBadgeNeutralBorderBrush" Color="#D9E2F5" />
    <SolidColorBrush x:Key="StudentDashboardPopupOverlayBrush" Color="#990B1C30" />

    <Style x:Key="StudentDashboardGreetingTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="34" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="StudentDashboardSupportingTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="StudentDashboardCardTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="StudentDashboardMetricValueTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="StudentDashboardQuickActionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="StudentDashboardSurfaceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StudentDashboardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardSurfaceHighestBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource StudentDashboardCardBorderThicknessValue}" />
        <Setter Property="CornerRadius" Value="{StaticResource StudentDashboardCardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource StudentDashboardCardPaddingThickness}" />
        <Setter Property="Effect" Value="{StaticResource StudentDashboardCardShadowEffect}" />
    </Style>

    <Style x:Key="StudentDashboardRefreshButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource StudentDashboardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardSurfaceHighestBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource StudentDashboardCardBorderThicknessValue}" />
        <Setter Property="Padding" Value="{StaticResource StudentDashboardRefreshButtonPadding}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource StudentDashboardPillCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource StudentDashboardSurfaceLowBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardQuickActionTileButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="132" />
        <Setter Property="Background" Value="{StaticResource StudentDashboardCanvasBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardSurfaceHighestBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource StudentDashboardCardBorderThicknessValue}" />
        <Setter Property="Padding" Value="{StaticResource StudentDashboardQuickActionTilePadding}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource StudentDashboardCardCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource StudentDashboardSurfaceLowBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardHeaderNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource StudentDashboardControlCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource StudentDashboardSurfaceHighBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextPrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardHeaderNavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource StudentDashboardHeaderNavButtonStyle}">
        <Setter Property="Background" Value="{StaticResource StudentDashboardPrimaryContainerTintBrush}" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="StudentDashboardHeaderIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
        <Setter Property="Width" Value="{StaticResource StudentDashboardHeaderIconButtonSize}" />
        <Setter Property="Height" Value="{StaticResource StudentDashboardHeaderIconButtonSize}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="Transparent"
                            CornerRadius="{StaticResource StudentDashboardIconButtonCornerRadius}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource StudentDashboardSurfaceLowBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardPrimaryCtaButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardPrimaryContainerBrush}" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardWhiteBrush}" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource StudentDashboardControlCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Opacity" Value="0.92" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource StudentDashboardSurfaceHighBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource StudentDashboardSurfaceHighBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardSummaryCardStyle" TargetType="Border" BasedOn="{StaticResource StudentDashboardSurfaceCardStyle}">
        <Setter Property="Width" Value="{StaticResource StudentDashboardSummaryCardWidth}" />
        <Setter Property="MinHeight" Value="{StaticResource StudentDashboardSummaryCardMinHeight}" />
        <Setter Property="Margin" Value="{StaticResource StudentDashboardSummaryCardMargin}" />
    </Style>

    <Style x:Key="StudentDashboardSummaryCardButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="HitArea" Background="Transparent">
                        <ContentPresenter HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HitArea" Property="Opacity" Value="0.98" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HitArea" Property="Opacity" Value="0.95" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter TargetName="HitArea" Property="Opacity" Value="0.96" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="StudentDashboardCardMetaTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
    </Style>

    <Style x:Key="StudentDashboardStatusLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardTextSecondaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StudentDashboardStatusPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource StudentDashboardBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StudentDashboardPopupStatusTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StudentDashboardCardMetaTextStyle}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource StudentDashboardPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

<Style x:Key="StudentDashboardCardInlineActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="StudentDashboardPopupBorderStyle" TargetType="Border">
        <Setter Property="MaxWidth" Value="{StaticResource StudentDashboardPopupWidth}" />
        <Setter Property="MaxHeight" Value="{StaticResource StudentDashboardPopupMaxHeight}" />
        <Setter Property="Background" Value="{StaticResource StudentDashboardSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StudentDashboardSurfaceContainerBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource StudentDashboardCardBorderThicknessValue}" />
        <Setter Property="CornerRadius" Value="{StaticResource StudentDashboardPopupCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource StudentDashboardPopupPadding}" />
        <Setter Property="Margin" Value="{StaticResource StudentDashboardPopupMargin}" />
        <Setter Property="Effect" Value="{StaticResource StudentDashboardPopupShadowEffect}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="StudentDashboardShellContentBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsStudentDashboardChrome}" Value="True">
                <Setter Property="Background" Value="{StaticResource StudentDashboardCanvasBrush}" />
