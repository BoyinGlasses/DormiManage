    <system:Double x:Key="StudentDashboardHeaderMinHeight">78</system:Double>
    <system:Double x:Key="StudentDashboardTopBarVerticalPadding">12</system:Double>
    <system:Double x:Key="StudentDashboardTopBarHorizontalPaddingDesktop">32</system:Double>
    <system:Double x:Key="StudentDashboardPagePaddingDesktop">24</system:Double>
    <system:Double x:Key="StudentDashboardPagePaddingMobile">16</system:Double>
