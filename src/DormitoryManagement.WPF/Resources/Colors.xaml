<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Foundation -->
    <Color x:Key="ColorBackground">#F5F7FA</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceAlt">#F8FAFC</Color>
    <Color x:Key="ColorSurfaceRaised">#FFFFFF</Color>
    <Color x:Key="ColorSurfaceMuted">#EEF2F6</Color>

    <!-- Border -->
    <Color x:Key="ColorBorder">#D9E2EC</Color>
    <Color x:Key="ColorBorderLight">#E9EEF5</Color>
    <Color x:Key="ColorFocusRing">#0F766E</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#172033</Color>
    <Color x:Key="ColorTextSecondary">#52616F</Color>
    <Color x:Key="ColorTextMuted">#7C8A99</Color>
    <Color x:Key="ColorTextInverted">#FFFFFF</Color>

    <!-- Brand -->
    <Color x:Key="ColorAccent">#0F766E</Color>
    <Color x:Key="ColorAccentHover">#115E59</Color>
    <Color x:Key="ColorAccentLight">#D6F3EF</Color>

    <Color x:Key="ColorPrimary">#2F5F98</Color>
    <Color x:Key="ColorPrimaryDark">#18324F</Color>
    <Color x:Key="ColorPrimaryHover">#264D7B</Color>
    <Color x:Key="ColorPrimaryLight">#E4EEF8</Color>

    <!-- Sidebar -->
    <Color x:Key="ColorSidebar">#172033</Color>
    <Color x:Key="ColorSidebarHover">#22314A</Color>
    <Color x:Key="ColorSidebarActive">#F5F8FC</Color>
    <Color x:Key="ColorSidebarText">#B8C4D4</Color>
    <Color x:Key="ColorSidebarTextActive">#172033</Color>

    <!-- Semantic -->
    <Color x:Key="ColorSuccess">#0F7A55</Color>
    <Color x:Key="ColorSuccessLight">#DCFCE7</Color>
    <Color x:Key="ColorWarning">#B45309</Color>
    <Color x:Key="ColorWarningLight">#FEF3C7</Color>
    <Color x:Key="ColorDanger">#B91C1C</Color>
    <Color x:Key="ColorDangerLight">#FEE2E2</Color>
    <Color x:Key="ColorInfo">#2F5F98</Color>
    <Color x:Key="ColorInfoLight">#E4EEF8</Color>
    <Color x:Key="ColorNeutral">#52616F</Color>
    <Color x:Key="ColorNeutralLight">#EEF2F6</Color>
    <Color x:Key="ColorDialogScrim">#66000000</Color>
    <Color x:Key="ColorSurfaceScrim">#AAFFFFFF</Color>
    <Color x:Key="ColorSurfaceScrimLight">#55FFFFFF</Color>
    <Color x:Key="ColorBadgeSuccessBorder">#A7F3D0</Color>
    <Color x:Key="ColorBadgeWarningBorder">#FCD34D</Color>
    <Color x:Key="ColorBadgeDangerBorder">#FCA5A5</Color>
    <Color x:Key="ColorBadgeInfoBorder">#BFDBFE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource ColorSurfaceAlt}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource ColorSurfaceRaised}" />
    <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource ColorSurfaceMuted}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource ColorBorderLight}" />
    <SolidColorBrush x:Key="FocusRingBrush" Color="{StaticResource ColorFocusRing}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource ColorTextMuted}" />
    <SolidColorBrush x:Key="TextInvertedBrush" Color="{StaticResource ColorTextInverted}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource ColorAccentHover}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource ColorAccentLight}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource ColorPrimaryDark}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource ColorPrimaryLight}" />

    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource ColorSidebar}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource ColorSidebarHover}" />
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource ColorSidebarActive}" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource ColorSidebarText}" />
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="{StaticResource ColorSidebarTextActive}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource ColorSuccessLight}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource ColorWarningLight}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource ColorDangerLight}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource ColorInfoLight}" />
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource ColorNeutral}" />
    <SolidColorBrush x:Key="NeutralLightBrush" Color="{StaticResource ColorNeutralLight}" />
    <SolidColorBrush x:Key="DialogScrimBrush" Color="{StaticResource ColorDialogScrim}" />
    <SolidColorBrush x:Key="SurfaceScrimBrush" Color="{StaticResource ColorSurfaceScrim}" />
    <SolidColorBrush x:Key="SurfaceScrimLightBrush" Color="{StaticResource ColorSurfaceScrimLight}" />

    <!-- Legacy aliases for backward compat -->
    <SolidColorBrush x:Key="PageBrush" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource ColorTextPrimary}" />
</ResourceDictionary>
