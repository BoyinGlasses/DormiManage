<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="ForumPostDetailColorCanvas">#F8F9FF</Color>
    <Color x:Key="ForumPostDetailColorSurface">#FFFFFF</Color>
    <Color x:Key="ForumPostDetailColorSurfaceLow">#EFF4FF</Color>
    <Color x:Key="ForumPostDetailColorSurfaceHigh">#DCE9FF</Color>
    <Color x:Key="ForumPostDetailColorSurfaceHighest">#D3E4FE</Color>
    <Color x:Key="ForumPostDetailColorOutline">#E1BFB5</Color>
    <Color x:Key="ForumPostDetailColorTextPrimary">#0B1C30</Color>
    <Color x:Key="ForumPostDetailColorTextSecondary">#594139</Color>
    <Color x:Key="ForumPostDetailColorPrimary">#AB3500</Color>
    <Color x:Key="ForumPostDetailColorPrimaryContainer">#FF6B35</Color>
    <Color x:Key="ForumPostDetailColorSecondaryContainer">#6063EE</Color>
    <Color x:Key="ForumPostDetailColorTertiaryContainer">#00AF79</Color>
    <Color x:Key="ForumPostDetailColorError">#BA1A1A</Color>
    <Color x:Key="ForumPostDetailColorErrorContainer">#FFDAD6</Color>

    <SolidColorBrush x:Key="ForumPostDetailCanvasBrush" Color="{StaticResource ForumPostDetailColorCanvas}" />
    <SolidColorBrush x:Key="ForumPostDetailSurfaceBrush" Color="{StaticResource ForumPostDetailColorSurface}" />
    <SolidColorBrush x:Key="ForumPostDetailSurfaceLowBrush" Color="{StaticResource ForumPostDetailColorSurfaceLow}" />
    <SolidColorBrush x:Key="ForumPostDetailSurfaceHighBrush" Color="{StaticResource ForumPostDetailColorSurfaceHigh}" />
    <SolidColorBrush x:Key="ForumPostDetailSurfaceHighestBrush" Color="{StaticResource ForumPostDetailColorSurfaceHighest}" />
    <SolidColorBrush x:Key="ForumPostDetailOutlineBrush" Color="{StaticResource ForumPostDetailColorOutline}" />
    <SolidColorBrush x:Key="ForumPostDetailTextPrimaryBrush" Color="{StaticResource ForumPostDetailColorTextPrimary}" />
    <SolidColorBrush x:Key="ForumPostDetailTextSecondaryBrush" Color="{StaticResource ForumPostDetailColorTextSecondary}" />
    <SolidColorBrush x:Key="ForumPostDetailPrimaryBrush" Color="{StaticResource ForumPostDetailColorPrimary}" />
    <SolidColorBrush x:Key="ForumPostDetailPrimaryContainerBrush" Color="{StaticResource ForumPostDetailColorPrimaryContainer}" />
    <SolidColorBrush x:Key="ForumPostDetailSecondaryContainerBrush" Color="{StaticResource ForumPostDetailColorSecondaryContainer}" />
    <SolidColorBrush x:Key="ForumPostDetailTertiaryContainerBrush" Color="{StaticResource ForumPostDetailColorTertiaryContainer}" />
    <SolidColorBrush x:Key="ForumPostDetailErrorBrush" Color="{StaticResource ForumPostDetailColorError}" />
    <SolidColorBrush x:Key="ForumPostDetailErrorContainerBrush" Color="{StaticResource ForumPostDetailColorErrorContainer}" />

    <FontFamily x:Key="ForumPostDetailHeadlineFontFamily">pack://application:,,,/DormitoryManagement.WPF;component/Assets/Fonts/PlusJakartaSans/#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="ForumPostDetailBodyFontFamily">pack://application:,,,/DormitoryManagement.WPF;component/Assets/Fonts/Inter/#Inter</FontFamily>

    <Style x:Key="ForumPostDetailBrandTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailPrimaryBrush}" />
    </Style>

    <Style x:Key="ForumPostDetailHeadlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ForumPostDetailDisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ForumPostDetailBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailBodyFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextPrimaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ForumPostDetailMetaTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailBodyFontFamily}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ForumPostDetailCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ForumPostDetailSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ForumPostDetailOutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
    </Style>

    <Style x:Key="ForumPostDetailGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ForumPostDetailFilledButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ForumPostDetailPrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource ForumPostDetailPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailBodyFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="ForumPostDetailOutlinePillButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ForumPostDetailSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumPostDetailTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="#D6E0F7" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontFamily" Value="{StaticResource ForumPostDetailBodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
</ResourceDictionary>
