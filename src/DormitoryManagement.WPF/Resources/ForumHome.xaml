<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <Color x:Key="ForumHomeColorCanvas">#F8F9FF</Color>
    <Color x:Key="ForumHomeColorSurface">#FFFFFF</Color>
    <Color x:Key="ForumHomeColorSurfaceLow">#EFF4FF</Color>
    <Color x:Key="ForumHomeColorSurfaceContainer">#E5EEFF</Color>
    <Color x:Key="ForumHomeColorSurfaceHigh">#DCE9FF</Color>
    <Color x:Key="ForumHomeColorSurfaceHighest">#D3E4FE</Color>
    <Color x:Key="ForumHomeColorOutline">#8D7168</Color>
    <Color x:Key="ForumHomeColorOutlineVariant">#E1BFB5</Color>
    <Color x:Key="ForumHomeColorTextPrimary">#0B1C30</Color>
    <Color x:Key="ForumHomeColorTextSecondary">#594139</Color>
    <Color x:Key="ForumHomeColorTextMuted">#594139</Color>
    <Color x:Key="ForumHomeColorPrimary">#AB3500</Color>
    <Color x:Key="ForumHomeColorPrimaryContainer">#FF6B35</Color>
    <Color x:Key="ForumHomeColorPrimaryDark">#832600</Color>
    <Color x:Key="ForumHomeColorSecondary">#4648D4</Color>
    <Color x:Key="ForumHomeColorSecondaryContainer">#6063EE</Color>
    <Color x:Key="ForumHomeColorTertiary">#006C49</Color>
    <Color x:Key="ForumHomeColorTertiaryContainer">#00AF79</Color>
    <Color x:Key="ForumHomeColorDanger">#BA1A1A</Color>
    <Color x:Key="ForumHomeColorWhite">#FFFFFF</Color>

    <SolidColorBrush x:Key="ForumHomeCanvasBrush" Color="{StaticResource ForumHomeColorCanvas}" />
    <SolidColorBrush x:Key="ForumHomeSurfaceBrush" Color="{StaticResource ForumHomeColorSurface}" />
    <SolidColorBrush x:Key="ForumHomeSurfaceLowBrush" Color="{StaticResource ForumHomeColorSurfaceLow}" />
    <SolidColorBrush x:Key="ForumHomeSurfaceContainerBrush" Color="{StaticResource ForumHomeColorSurfaceContainer}" />
    <SolidColorBrush x:Key="ForumHomeSurfaceHighBrush" Color="{StaticResource ForumHomeColorSurfaceHigh}" />
    <SolidColorBrush x:Key="ForumHomeSurfaceHighestBrush" Color="{StaticResource ForumHomeColorSurfaceHighest}" />
    <SolidColorBrush x:Key="ForumHomeOutlineBrush" Color="{StaticResource ForumHomeColorOutlineVariant}" />
    <SolidColorBrush x:Key="ForumHomeOutlineVariantBrush" Color="{StaticResource ForumHomeColorOutlineVariant}" />
    <SolidColorBrush x:Key="ForumHomeTextPrimaryBrush" Color="{StaticResource ForumHomeColorTextPrimary}" />
    <SolidColorBrush x:Key="ForumHomeTextSecondaryBrush" Color="{StaticResource ForumHomeColorTextSecondary}" />
    <SolidColorBrush x:Key="ForumHomeTextMutedBrush" Color="{StaticResource ForumHomeColorTextMuted}" />
    <SolidColorBrush x:Key="ForumHomePrimaryBrush" Color="{StaticResource ForumHomeColorPrimary}" />
    <SolidColorBrush x:Key="ForumHomePrimarySubtleBrush" Color="#0DAB3500" />
    <SolidColorBrush x:Key="ForumHomePrimaryContainerBrush" Color="{StaticResource ForumHomeColorPrimaryContainer}" />
    <SolidColorBrush x:Key="ForumHomePrimaryDarkBrush" Color="{StaticResource ForumHomeColorPrimaryDark}" />
    <SolidColorBrush x:Key="ForumHomeSecondaryBrush" Color="{StaticResource ForumHomeColorSecondary}" />
    <SolidColorBrush x:Key="ForumHomeSecondaryContainerBrush" Color="{StaticResource ForumHomeColorSecondaryContainer}" />
    <SolidColorBrush x:Key="ForumHomeTertiaryBrush" Color="{StaticResource ForumHomeColorTertiary}" />
    <SolidColorBrush x:Key="ForumHomeTertiaryContainerBrush" Color="{StaticResource ForumHomeColorTertiaryContainer}" />
    <SolidColorBrush x:Key="ForumHomeDangerBrush" Color="{StaticResource ForumHomeColorDanger}" />
    <SolidColorBrush x:Key="ForumHomeWhiteBrush" Color="{StaticResource ForumHomeColorWhite}" />

    <FontFamily x:Key="ForumHomeHeadlineFontFamily">pack://application:,,,/DormitoryManagement.WPF;component/Assets/Fonts/PlusJakartaSans/#Plus Jakarta Sans</FontFamily>
    <FontFamily x:Key="ForumHomeBodyFontFamily">pack://application:,,,/DormitoryManagement.WPF;component/Assets/Fonts/Inter/#Inter</FontFamily>

    <system:Double x:Key="ForumHomeDisplayLargeSize">48</system:Double>
    <system:Double x:Key="ForumHomeHeadlineLargeSize">32</system:Double>
    <system:Double x:Key="ForumHomeHeadlineMediumSize">24</system:Double>
    <system:Double x:Key="ForumHomeHeadlineSmallSize">18</system:Double>
    <system:Double x:Key="ForumHomeBodyLargeSize">16</system:Double>
    <system:Double x:Key="ForumHomeBodyMediumSize">14</system:Double>
    <system:Double x:Key="ForumHomeLabelMediumSize">14</system:Double>
    <system:Double x:Key="ForumHomeLabelSmallSize">12</system:Double>
    <system:Double x:Key="ForumHomeHeaderHeight">64</system:Double>
    <system:Double x:Key="ForumHomeMarginDesktop">32</system:Double>
    <system:Double x:Key="ForumHomeMarginMobile">16</system:Double>
    <system:Double x:Key="ForumHomeGutter">24</system:Double>
    <system:Double x:Key="ForumHomeContainerMaxWidth">1440</system:Double>
    <system:Double x:Key="ForumHomeStackSmall">8</system:Double>
    <system:Double x:Key="ForumHomeStackMedium">16</system:Double>
    <system:Double x:Key="ForumHomeStackLarge">24</system:Double>

    <CornerRadius x:Key="ForumHomeControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ForumHomeCardCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ForumHomeFeaturedCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="ForumHomePillCornerRadius">999</CornerRadius>

    <Thickness x:Key="ForumHomeCardPadding">24</Thickness>
    <Thickness x:Key="ForumHomeCompactPadding">16</Thickness>
    <Thickness x:Key="ForumHomeInputPadding">16,8</Thickness>
    <Thickness x:Key="ForumHomeChipPadding">12,4</Thickness>
    <Thickness x:Key="ForumHomeSectionSpacing">0,0,0,24</Thickness>

    <DropShadowEffect x:Key="ForumHomeCardShadow"
                      BlurRadius="20"
                      Color="#14000000"
                      Opacity="0.18"
                      ShadowDepth="4" />
    <DropShadowEffect x:Key="ForumHomeCardHoverShadow"
                      BlurRadius="30"
                      Color="#1F000000"
                      Opacity="0.24"
                      ShadowDepth="8" />
    <DropShadowEffect x:Key="ForumHomeCardFocusShadow"
                      BlurRadius="32"
                      Color="#33AB3500"
                      Opacity="0.26"
                      ShadowDepth="10" />

    <Style x:Key="ForumHomeDisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeDisplayLargeSize}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="56" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeBrandTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeHeadlineMediumSize}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
        <Setter Property="LineHeight" Value="32" />
        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeHeadlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeHeadlineSmallSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeHeadlineMediumTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeHeadlineFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeHeadlineMediumSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="32" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeBodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeBodyLargeSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeLabelMediumTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeLabelMediumSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeMetaTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeBodyMediumSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeSectionLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeLabelSmallSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
        <Setter Property="LineHeight" Value="16" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="ForumHomeCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource ForumHomeCardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource ForumHomeCardPadding}" />
        <Setter Property="Effect" Value="{StaticResource ForumHomeCardShadow}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
                <Setter Property="Effect" Value="{StaticResource ForumHomeCardHoverShadow}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="Effect" Value="{StaticResource ForumHomeCardFocusShadow}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomeFeaturedBorderStyle" TargetType="Border" BasedOn="{StaticResource ForumHomeCardBorderStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource ForumHomeFeaturedCornerRadius}" />
    </Style>

    <Style x:Key="ForumHomeDropdownBorderStyle" TargetType="Border" BasedOn="{StaticResource ForumHomeCardBorderStyle}">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="ForumHomeEmptyStateBorderStyle" TargetType="Border" BasedOn="{StaticResource ForumHomeCardBorderStyle}">
        <Setter Property="Padding" Value="28" />
    </Style>

    <Style x:Key="ForumHomePrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ForumHomePrimaryContainerBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeWhiteBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryContainerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="18,9" />
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeLabelMediumSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ForumHomeControlCornerRadius}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryDarkBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryDarkBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomeWhiteBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomeGhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeBodyMediumSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ForumHomeControlCornerRadius}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryDarkBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomeSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ForumHomeGhostButtonStyle}">
        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
        <Setter Property="Padding" Value="14,8" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryDarkBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomeChipButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="{StaticResource ForumHomeChipPadding}" />
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeLabelSmallSize}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ForumHomePillCornerRadius}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighestBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighestBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeWhiteBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryContainerBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeWhiteBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ForumHomePrimaryContainerBrush}" />
            </DataTrigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomePopularTagButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,5" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeLabelMediumSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="17">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighestBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceHighestBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomePrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeWhiteBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="{StaticResource ForumHomePrimaryBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ForumHomeWhiteBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ForumHomeTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ForumHomeTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource ForumHomeInputPadding}" />
        <Setter Property="FontFamily" Value="{StaticResource ForumHomeBodyFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource ForumHomeBodyMediumSize}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ForumHomeControlCornerRadius}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource ForumHomeSurfaceBrush}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource ForumHomePrimaryBrush}" />
                            <Setter TargetName="Border" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource ForumHomeSurfaceLowBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource ForumHomeTextMutedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>



