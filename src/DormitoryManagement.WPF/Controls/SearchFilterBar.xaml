<UserControl x:Class="DormitoryManagement.WPF.Controls.SearchFilterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource SectionCardStyle}" Padding="16" Margin="0,0,0,16">
        <StackPanel>
            <TextBlock Text="Search and filters" Style="{StaticResource LabelText}" Margin="0,0,0,12" />
            <ContentPresenter Content="{Binding FilterContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </StackPanel>
    </Border>
</UserControl>
