<UserControl x:Class="DormitoryManagement.WPF.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="30"
            MinHeight="180">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
            <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource SurfaceAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontFamily="Segoe Fluent Icons"
                           FontSize="20"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource TitleText}"
                       TextAlignment="Center"
                       Margin="0,12,0,4" />
            <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource SubtitleText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</UserControl>
