<UserControl x:Class="DormitoryManagement.WPF.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource SurfaceScrimBrush}" IsHitTestVisible="True">
        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="96" Height="6" IsIndeterminate="True" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource SubtitleText}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
